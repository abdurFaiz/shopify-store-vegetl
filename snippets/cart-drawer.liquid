<div
  id="cart-drawer-overlay"
  aria-hidden="true"
  style="
    position: fixed; inset: 0; z-index: 900;
    background: rgba(26,32,27,0.35);
    backdrop-filter: blur(4px);
    opacity: 0; pointer-events: none;
    transition: opacity 0.35s ease;
  "
></div>

<div
  id="cart-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Shopping cart"
  style="
    position: fixed; top: 0; right: 0; bottom: 0;
    width: min(420px, 100vw);
    z-index: 901;
    background: #fff;
    display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.32, 0, 0.15, 1);
    box-shadow: -8px 0 40px rgba(26,32,27,0.12);
    border-radius: 24px 0 0 24px;
    overflow: hidden;
  "
>
  <!-- Header -->
  <div
    style="
      display: flex; align-items: center; justify-content: space-between;
      padding: 24px 24px 20px;
      border-bottom: 1px solid #f0f0f0;
      flex-shrink: 0;
    "
  >
    <div style="display: flex; align-items: center; gap: 10px;">
      <span style="font-size: 20px; color: #1a201b;">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="size-6"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
        </svg>
      </span>
      <h2 style="font-size: 18px; font-weight: 700; color: #1a201b; margin: 0; letter-spacing: -0.02em;">Your Cart</h2>
      <span
        id="cart-drawer-count-badge"
        style="
          background: #0f3f21; color: #fff;
          font-size: 11px; font-weight: 700;
          min-width: 20px; height: 20px;
          border-radius: 999px;
          display: flex; align-items: center; justify-content: center;
          padding: 0 6px;
        "
      >
        {{- cart.item_count -}}
      </span>
    </div>
    <button
      id="cart-drawer-close"
      aria-label="Close cart"
      style="
        width: 36px; height: 36px;
        border-radius: 50%;
        border: 1px solid #e5e7eb;
        background: #fff;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; color: #1a201b;
        transition: background 0.2s;
        flex-shrink: 0;
      "
      onmouseover="this.style.background='#f3f4f6'"
      onmouseout="this.style.background='#fff'"
    >
      <span style="font-size: 18px;">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="size-6"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </span>
    </button>
  </div>

  <!-- Items list -->
  <div id="cart-drawer-items" style="flex: 1; overflow-y: auto; padding: 16px 24px;">
    {% render 'cart-drawer-items' %}
  </div>

  <!-- Footer -->
  <div
    id="cart-drawer-footer"
    style="
      flex-shrink: 0;
      border-top: 1px solid #f0f0f0;
      padding: 20px 24px 28px;
    "
  >
    {% render 'cart-drawer-footer' %}
  </div>
</div>

<style>
  #cart-drawer::-webkit-scrollbar {
    display: none;
  }
  #cart-drawer-items::-webkit-scrollbar {
    width: 4px;
  }
  #cart-drawer-items::-webkit-scrollbar-track {
    background: transparent;
  }
  #cart-drawer-items::-webkit-scrollbar-thumb {
    background: #e5e7eb;
    border-radius: 4px;
  }

  .cart-drawer-open #cart-drawer-overlay {
    opacity: 1 !important;
    pointer-events: auto !important;
  }
  .cart-drawer-open #cart-drawer {
    transform: translateX(0) !important;
  }

  .cart-qty-btn {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid #e5e7eb;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #1a201b;
    font-size: 14px;
    transition: background 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }
  .cart-qty-btn:hover {
    background: #f3f4f6;
    border-color: #d1d5db;
  }
  .cart-remove-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: #9ca3af;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s;
    padding: 4px;
    border-radius: 6px;
  }
  .cart-remove-btn:hover {
    color: #ef4444;
  }

  #cart-drawer-items[aria-busy='true'] {
    opacity: 0.5;
    pointer-events: none;
    transition: opacity 0.2s;
  }
</style>

<script>
  (function () {
    const drawer = document.getElementById('cart-drawer');
    const overlay = document.getElementById('cart-drawer-overlay');
    const closeBtn = document.getElementById('cart-drawer-close');
    const itemsEl = document.getElementById('cart-drawer-items');
    const footerEl = document.getElementById('cart-drawer-footer');
    const badgeEl = document.getElementById('cart-drawer-count-badge');

    /* ── open / close ───────────────────────────────────── */
    function openDrawer() {
      document.body.classList.add('cart-drawer-open');
    }
    function closeDrawer() {
      document.body.classList.remove('cart-drawer-open');
    }

    closeBtn.addEventListener('click', closeDrawer);
    overlay.addEventListener('click', closeDrawer);
    document.addEventListener('cart:open', openDrawer);

    /* ── Section Rendering API refresh ─────────────────── */
    async function refreshCart() {
      itemsEl.setAttribute('aria-busy', 'true');

      try {
        const url = `${window.Shopify.routes.root}?sections=cart-drawer-body`;
        const res = await fetch(url);
        if (!res.ok) throw new Error('Section fetch failed: ' + res.status);

        const data = await res.json();
        const html = data['cart-drawer-body'];

        /* Parse the returned section HTML */
        const doc = new DOMParser().parseFromString(html, 'text/html');

        /* Swap items */
        const newItems = doc.getElementById('cart-drawer-items-inner');
        if (newItems) itemsEl.innerHTML = newItems.outerHTML;

        /* Swap footer */
        const newFooter = doc.getElementById('cart-drawer-footer-inner');
        if (newFooter) footerEl.innerHTML = newFooter.outerHTML;

        /* Update badge counts */
        const countEl = doc.getElementById('cart-drawer-count-inner');
        const count = countEl ? parseInt(countEl.textContent.trim(), 10) : 0;

        if (badgeEl) badgeEl.textContent = count;
        document.querySelectorAll('[data-cart-count]').forEach((el) => {
          el.textContent = count;
          el.style.display = count > 0 ? 'flex' : 'none';
        });

        /* Re-bind interactive buttons */
        bindCartButtons();
      } catch (e) {
        console.error('Cart refresh failed', e);
      } finally {
        itemsEl.removeAttribute('aria-busy');
      }
    }

    /* ── bind qty + remove buttons ──────────────────────── */
    function bindCartButtons() {
      itemsEl.querySelectorAll('.cart-qty-btn').forEach((btn) => {
        btn.addEventListener('click', () => updateLine(btn.dataset.line, parseInt(btn.dataset.qty, 10)));
      });
      itemsEl.querySelectorAll('.cart-remove-btn').forEach((btn) => {
        btn.addEventListener('click', () => updateLine(btn.dataset.line, 0));
      });
    }

    /* ── update line quantity ────────────────────────────── */
    async function updateLine(line, qty) {
      try {
        const res = await fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ line: parseInt(line, 10), quantity: qty }),
        });
        if (!res.ok) throw new Error('Cart change failed: ' + res.status);
        await refreshCart();
      } catch (e) {
        console.error('Failed to update cart', e);
      }
    }

    /* ── listen for add-to-cart events ──────────────────── */
    document.addEventListener('cart:added', async () => {
      await refreshCart();
      openDrawer();
    });

    /* ── bind initial server-rendered buttons ────────────── */
    bindCartButtons();
  })();
</script>
