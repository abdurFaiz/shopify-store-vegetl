<section class="py-12 lg:py-24 bg-white full-width w-full overflow-hidden" id="testimonial-section-{{ id_suffix | default: section.id }}">
  <div class="max-w-[1300px] mx-auto px-4 lg:px-6 w-full">
    <!-- TOP HEADER -->
    <div class="mb-14 lg:mb-20">
      <span class="inline-flex items-center text-gray-600 border border-gray-200 px-3.5 py-1.5 rounded-full text-[12px] font-medium tracking-wide mb-6 bg-white shadow-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-[#006400] mr-2"></span>
        Testimonials
      </span>

      <div class="flex flex-col lg:flex-row lg:justify-between lg:items-end gap-6">
        <h2 class="text-4xl md:text-[52px] leading-tight text-[#1a201b] font-semibold tracking-tight max-w-[700px]">
          Real Stories From <span class="font-normal italic text-gray-700">Our Farmers</span>
        </h2>

        <p class="max-w-[360px] text-[15px] text-gray-600 leading-relaxed text-left lg:text-right pb-2">
          Read real experiences from farmers who grow with us, sharing trust, quality, and success from field to market.
        </p>
      </div>
    </div>

    <!-- MAIN CONTENT GRID SLIDER -->
    {%- assign slider_id = 'testimonial-slider-' | append: id_suffix | default: 'testimonial-slider-' | append: section.id -%}
    {%- assign track_id = 'testimonial-track-' | append: id_suffix | default: 'testimonial-track-' | append: section.id -%}
    <div class="relative w-full" id="{{ slider_id }}">
      <!-- ARROW NAVIGATION (STATIC, ONLY 1 PAIR) -->
      <div class="absolute bottom-0 right-0 z-10 flex items-center gap-3 pointer-events-none">
        <div class=" pointer-events-auto flex gap-3 pl-4">
          <button class="testimonial-prev w-12 h-12 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-600 hover:bg-gray-50 transition-colors shadow-sm focus:outline-none">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
          </button>
          <button class="testimonial-next w-12 h-12 rounded-full bg-[#006400] flex items-center justify-center text-white hover:bg-green-800 transition-colors shadow-md focus:outline-none">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="overflow-hidden w-full relative">
        <div class="flex transition-transform duration-700 ease-in-out w-full" id="{{ track_id }}">
          <!-- Testimonial 1 -->
          <div class="w-full flex-shrink-0 grid grid-cols-1 lg:grid-cols-[0.6fr_1.3fr] gap-10 lg:gap-16 items-center">
            <div class="w-full aspect-square md:aspect-[4/3] h-full rounded-[40px] overflow-hidden bg-gray-100">
              <img
                src="{{ 'testimonial.png' | file_url }}"
                alt="Farmer"
                class="w-full h-full object-cover transition-transform duration-1000 bg-gray-100"
                loading="lazy"
                height="400"
                width="400"
              >
            </div>
            <div class="flex flex-col">
              <div class="text-[26px] sm:text-[30px] md:text-[36px] leading-[1.3] font-medium tracking-tight mb-12 sm:mb-16">
                <span class="text-[#1a201b]"
                  >"I have been farming for over 15 years, but working with this platform completely changed how
                </span>
                <span class="text-gray-500"
                  >I sell my produce. Fair prices, timely support, and genuine care for farmers made a real difference
                  for my family and my land."</span
                >
              </div>
              <div class="flex items-center justify-between mt-auto pb-1 md:pb-0">
                <div class="flex flex-col">
                  <span class="text-[#1a201b] font-bold text-[18px]">Aaron Mitchell</span>
                  <span class="text-gray-500 text-[14px] mt-0.5">Florida, United States</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Testimonial 2 -->
          <div class="w-full flex-shrink-0 grid grid-cols-1 lg:grid-cols-[0.6fr_1.3fr] gap-10 lg:gap-16 items-center">
            <div class="w-full aspect-square md:aspect-[4/3] h-full rounded-[40px] overflow-hidden bg-gray-100">
              <img
                src="{{ 'testimonial-2.png' | file_url }}"
                alt="Farmer"
                class="w-full h-full object-cover transition-transform duration-1000 bg-gray-100"
                loading="lazy"
                height="400"
                width="400"
              >
            </div>
            <div class="flex flex-col">
              <div class="text-[26px] sm:text-[30px] md:text-[36px] leading-[1.3] font-medium tracking-tight mb-12 sm:mb-16">
                <span class="text-[#1a201b]">"It's amazing how much easier tracking orders has become. </span>
                <span class="text-gray-500"
                  >The logistics used to give me headaches, but now everything is smooth, and I get paid faster than
                  ever."</span
                >
              </div>
              <div class="flex items-center justify-between mt-auto pb-1 md:pb-0">
                <div class="flex flex-col">
                  <span class="text-[#1a201b] font-bold text-[18px]">Sarah Jenkins</span>
                  <span class="text-gray-500 text-[14px] mt-0.5">California, United States</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Testimonial 3 -->
          <div class="w-full flex-shrink-0 grid grid-cols-1 lg:grid-cols-[0.6fr_1.3fr] gap-10 lg:gap-16 items-center">
            <div class="w-full aspect-square md:aspect-[4/3] h-full rounded-[40px] overflow-hidden bg-gray-100">
              <img
                src="{{ 'testimonial-3.png' | file_url }}"
                alt="Farmer"
                class="w-full h-full object-cover transition-transform duration-1000 bg-gray-100"
                loading="lazy"
                height="400"
                width="400"
              >
            </div>
            <div class="flex flex-col">
              <div class="text-[26px] sm:text-[30px] md:text-[36px] leading-[1.3] font-medium tracking-tight mb-12 sm:mb-16">
                <span class="text-[#1a201b]">"My crop yield significantly increased after utilizing the insights </span>
                <span class="text-gray-500"
                  >provided by this service. The community of farmers here is also incredibly supportive."</span
                >
              </div>
              <div class="flex items-center justify-between mt-auto pb-1 md:pb-0">
                <div class="flex flex-col">
                  <span class="text-[#1a201b] font-bold text-[18px]">David Choi</span>
                  <span class="text-gray-500 text-[14px] mt-0.5">Oregon, United States</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var sliderId = '{{ slider_id }}';
    var trackId = '{{ track_id }}';
    var track = document.getElementById(trackId);
    if (!track) return;

    var currentSlide = 0;
    var slidesCount = track.children.length;

    if (slidesCount <= 1) return;

    function moveSlide(direction) {
      if (direction === 'next') {
        currentSlide = (currentSlide + 1) % slidesCount;
      } else {
        currentSlide = (currentSlide - 1 + slidesCount) % slidesCount;
      }
      track.style.transform = 'translateX(-' + (currentSlide * 100) + '%)';
    }

    var sliderElement = document.getElementById(sliderId);
    if (!sliderElement) return;

    sliderElement.querySelectorAll('.testimonial-prev').forEach(function (btn) {
      btn.addEventListener('click', function () { moveSlide('prev'); });
    });
    sliderElement.querySelectorAll('.testimonial-next').forEach(function (btn) {
      btn.addEventListener('click', function () { moveSlide('next'); });
    });
  });
</script>
