{% doc %}
  Renders the initial server-side cart line items inside the cart drawer.
  This is replaced by JS after every cart mutation.
{% enddoc %}

{% if cart.item_count == 0 %}
  <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:200px;gap:12px;color:#9ca3af;">
    <span class="material-symbols-outlined" style="font-size:48px;opacity:0.4;">shopping_basket</span>
    <p style="font-size:14px;font-weight:500;">Your cart is empty</p>
  </div>
{% else %}
  {% for item in cart.items %}
    <div
      data-line="{{ forloop.index }}"
      style="display:flex;gap:14px;padding:14px 0;border-bottom:1px solid #f3f4f6;align-items:flex-start;"
    >
      <a href="{{ item.url }}" style="flex-shrink:0;">
        <img
          src="{{ item.image | image_url: width: 144 }}"
          alt="{{ item.product.title | escape }}"
          width="72" height="72"
          style="width:72px;height:72px;object-fit:cover;border-radius:16px;background:#f3f4f6;border:1px solid #e5e7eb;"
          loading="lazy"
        >
      </a>
      <div style="flex:1;min-width:0;">
        <a href="{{ item.url }}" style="text-decoration:none;">
          <p style="font-size:14px;font-weight:700;color:#1a201b;margin:0 0 2px;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
            {{ item.product.title }}
          </p>
        </a>
        {% unless item.variant.title == 'Default Title' %}
          <p style="font-size:12px;color:#9ca3af;margin:0 0 8px;">{{ item.variant.title }}</p>
        {% else %}
          <div style="margin-bottom:8px;"></div>
        {% endunless %}
        <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
          <div style="display:flex;align-items:center;gap:8px;">
            <button class="cart-qty-btn" data-action="decrease" data-line="{{ forloop.index }}" data-qty="{{ item.quantity | minus: 1 }}" aria-label="Decrease quantity">
              <span class="material-symbols-outlined" style="font-size:14px;">remove</span>
            </button>
            <span style="font-size:14px;font-weight:600;color:#1a201b;min-width:16px;text-align:center;">{{ item.quantity }}</span>
            <button class="cart-qty-btn" data-action="increase" data-line="{{ forloop.index }}" data-qty="{{ item.quantity | plus: 1 }}" aria-label="Increase quantity">
              <span class="material-symbols-outlined" style="font-size:14px;">add</span>
            </button>
          </div>
          <span style="font-size:14px;font-weight:700;color:#1a201b;white-space:nowrap;">{{ item.line_price | money }}</span>
        </div>
      </div>
      <button class="cart-remove-btn" data-line="{{ forloop.index }}" aria-label="Remove item">
        <span class="material-symbols-outlined" style="font-size:18px;">delete</span>
      </button>
    </div>
  {% endfor %}
{% endif %}
