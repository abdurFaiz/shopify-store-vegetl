{% if cart.item_count == 0 %}
  <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:200px;gap:12px;color:#9ca3af;">
    <span style="font-size:48px;opacity:0.4;">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-6"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
      </svg>
    </span>
    <p style="font-size:14px;font-weight:500;">Your cart is empty</p>
  </div>
{% else %}
  {% for item in cart.items %}
    <div
      data-line="{{ forloop.index }}"
      style="display:flex;gap:14px;padding:14px 0;border-bottom:1px solid #f3f4f6;align-items:flex-start;"
    >
      <a href="{{ item.url }}" style="flex-shrink:0;">
        <img
          src="{{ item.image | image_url: width: 144 }}"
          alt="{{ item.product.title | escape }}"
          width="72"
          height="72"
          style="width:72px;height:72px;object-fit:cover;border-radius:16px;background:#f3f4f6;border:1px solid #e5e7eb;"
          loading="lazy"
        >
      </a>
      <div style="flex:1;min-width:0;">
        <a href="{{ item.url }}" style="text-decoration:none;">
          <p style="font-size:14px;font-weight:700;color:#1a201b;margin:0 0 2px;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
            {{ item.product.title }}
          </p>
        </a>
        {% unless item.variant.title == 'Default Title' %}
          <p style="font-size:12px;color:#9ca3af;margin:0 0 8px;">{{ item.variant.title }}</p>
        {% else %}
          <div style="margin-bottom:8px;"></div>
        {% endunless %}
        <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
          <div style="display:flex;align-items:center;gap:8px;">
            <button
              class="cart-qty-btn"
              data-action="decrease"
              data-line="{{ forloop.index }}"
              data-qty="{{ item.quantity | minus: 1 }}"
              aria-label="Decrease quantity"
            >
              <span style="font-size:14px;">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="size-6"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
                </svg>
              </span>
            </button>
            <span style="font-size:14px;font-weight:600;color:#1a201b;min-width:16px;text-align:center;">
              {{- item.quantity -}}
            </span>
            <button
              class="cart-qty-btn"
              data-action="increase"
              data-line="{{ forloop.index }}"
              data-qty="{{ item.quantity | plus: 1 }}"
              aria-label="Increase quantity"
            >
              <span style="font-size:14px;">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="size-6"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
              </span>
            </button>
          </div>
          <span style="font-size:14px;font-weight:700;color:#1a201b;white-space:nowrap;">
            {{- item.line_price | money -}}
          </span>
        </div>
      </div>
      <button class="cart-remove-btn" data-line="{{ forloop.index }}" aria-label="Remove item">
        <span style="font-size:18px;">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="size-6"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
          </svg>
        </span>
      </button>
    </div>
  {% endfor %}
{% endif %}
