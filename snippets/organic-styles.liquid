{% doc %}
  Injects Tailwind CSS via CDN and required Google Fonts for the Organic theme.
  Used to exactly match the design.
{% enddoc %}


<!-- Anti-FOUC: hide body until Tailwind styles are applied -->
<style id="fouc-guard">html { visibility: hidden; }</style>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries" defer></script>
<script defer>
  document.addEventListener('DOMContentLoaded', function() {
    var guard = document.getElementById('fouc-guard');
    if (guard) guard.remove();
    document.documentElement.style.visibility = 'visible';
  });
</script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

<script id="tailwind-config">
  tailwind.config = {
    darkMode: "class",
    theme: {
      extend: {
        "colors": {
          "outline": "#6e7b6a",
          "secondary-container": "#b4eead",
          "on-tertiary": "#ffffff",
          "error": "#ba1a1a",
          "surface-container-high": "#e2eae1",
          "secondary-fixed": "#b7f1af",
          "on-surface-variant": "#3e4a3b",
          "primary-fixed": "#7ffd81",
          "on-secondary-fixed-variant": "#1d5120",
          "on-tertiary-fixed": "#400011",
          "primary-fixed-dim": "#62e068",
          "on-background": "#161d18",
          "on-secondary-container": "#3a6e39",
          "on-secondary": "#ffffff",
          "surface": "#f4fcf2",
          "tertiary-container": "#ff7d91",
          "inverse-on-surface": "#ebf3ea",
          "inverse-primary": "#62e068",
          "tertiary-fixed": "#ffd9dc",
          "primary-container": "#3dbd4a",
          "tertiary-fixed-dim": "#ffb2ba",
          "surface-container": "#e8f0e7",
          "inverse-surface": "#2b322c",
          "primary": "#006e1c",
          "on-primary-container": "#00460f",
          "on-error": "#ffffff",
          "outline-variant": "#bdcab7",
          "on-primary-fixed": "#002204",
          "tertiary": "#a4384d",
          "on-tertiary-fixed-variant": "#851f36",
          "on-primary-fixed-variant": "#005313",
          "secondary-fixed-dim": "#9cd595",
          "surface-dim": "#d4dcd3",
          "on-surface": "#161d18",
          "error-container": "#ffdad6",
          "background": "#f4fcf2",
          "on-primary": "#ffffff",
          "surface-container-lowest": "#ffffff",
          "surface-container-highest": "#dde5dc",
          "on-tertiary-container": "#75122c",
          "surface-variant": "#dde5dc",
          "on-secondary-fixed": "#002204",
          "secondary": "#366a35",
          "surface-bright": "#f4fcf2",
          "on-error-container": "#93000a",
          "surface-container-low": "#eef6ed",
          "surface-tint": "#006e1c"
        },
        "borderRadius": {
          "DEFAULT": "1rem",
          "lg": "2rem",
          "xl": "3rem",
          "full": "9999px"
        },
        "fontFamily": {
          "headline": ["Plus Jakarta Sans"],
          "body": ["Inter"],
          "label": ["Inter"]
        }
      }
    }
  }
</script>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
  .text-editorial-gradient {
    background: linear-gradient(155deg, #3DBD4A 0%, #006E1C 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
