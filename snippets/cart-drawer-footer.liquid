{% doc %}
  Renders the subtotal + checkout button in the cart drawer footer.
  This is replaced by JS after every cart mutation.
{% enddoc %}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
  <span style="font-size:14px;color:#6b7280;font-weight:500;">Subtotal</span>
  <span style="font-size:18px;font-weight:700;color:#1a201b;">{{ cart.total_price | money }}</span>
</div>
<p style="font-size:12px;color:#9ca3af;text-align:center;margin:0 0 14px;">
  Taxes and shipping calculated at checkout
</p>
<a
  href="/checkout"
  style="
    display:block;width:100%;
    background:#1a201b;color:#fff;
    text-align:center;
    padding:16px;
    border-radius:16px;
    font-size:14px;font-weight:700;
    text-decoration:none;
    letter-spacing:0.01em;
    transition:background 0.2s,transform 0.15s;
  "
  onmouseover="this.style.background='#006400';this.style.transform='translateY(-1px)'"
  onmouseout="this.style.background='#1a201b';this.style.transform='translateY(0)'"
>
  Checkout
</a>
<a
  href="/cart"
  style="
    display:block;width:100%;
    text-align:center;
    padding:12px;
    border-radius:16px;
    font-size:13px;font-weight:500;
    color:#6b7280;
    text-decoration:none;
    margin-top:8px;
    transition:color 0.2s;
  "
  onmouseover="this.style.color='#1a201b'"
  onmouseout="this.style.color='#6b7280'"
>
  View full cart →
</a>
