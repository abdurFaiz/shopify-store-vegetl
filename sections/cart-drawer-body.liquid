<div id="cart-drawer-items-inner">
  {% if cart.item_count == 0 %}
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:200px;gap:12px;color:#9ca3af;">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:48px;height:48px;opacity:0.4;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
      </svg>
      <p style="font-size:14px;font-weight:500;">Your cart is empty</p>
    </div>
  {% else %}
    {% for item in cart.items %}
      <div
        data-line="{{ forloop.index }}"
        style="display:flex;gap:14px;padding:14px 0;border-bottom:1px solid #f3f4f6;align-items:flex-start;"
      >
        <a href="{{ item.url }}" style="flex-shrink:0;">
          <img
            src="{{ item.image | image_url: width: 144 }}"
            alt="{{ item.product.title | escape }}"
            width="72" height="72"
            style="width:72px;height:72px;object-fit:cover;border-radius:16px;background:#f3f4f6;border:1px solid #e5e7eb;"
            loading="lazy"
          >
        </a>
        <div style="flex:1;min-width:0;">
          <a href="{{ item.url }}" style="text-decoration:none;">
            <p style="font-size:14px;font-weight:700;color:#1a201b;margin:0 0 2px;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
              {{ item.product.title }}
            </p>
          </a>
          {% unless item.variant.title == 'Default Title' %}
            <p style="font-size:12px;color:#9ca3af;margin:0 0 8px;">{{ item.variant.title }}</p>
          {% else %}
            <div style="margin-bottom:8px;"></div>
          {% endunless %}
          <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
            <div style="display:flex;align-items:center;gap:8px;">
              <button class="cart-qty-btn" data-action="decrease" data-line="{{ forloop.index }}" data-qty="{{ item.quantity | minus: 1 }}" aria-label="Decrease quantity">
                <span class="material-symbols-outlined" style="font-size:14px;">remove</span>
              </button>
              <span style="font-size:14px;font-weight:600;color:#1a201b;min-width:16px;text-align:center;">{{ item.quantity }}</span>
              <button class="cart-qty-btn" data-action="increase" data-line="{{ forloop.index }}" data-qty="{{ item.quantity | plus: 1 }}" aria-label="Increase quantity">
                <span class="material-symbols-outlined" style="font-size:14px;">add</span>
              </button>
            </div>
            <span style="font-size:14px;font-weight:700;color:#1a201b;white-space:nowrap;">{{ item.line_price | money }}</span>
          </div>
        </div>
        <button class="cart-remove-btn" data-line="{{ forloop.index }}" aria-label="Remove item">
          <span class="material-symbols-outlined" style="font-size:18px;">delete</span>
        </button>
      </div>
    {% endfor %}
  {% endif %}
</div>

<div id="cart-drawer-footer-inner">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
    <span style="font-size:14px;color:#6b7280;font-weight:500;">Subtotal</span>
    <span style="font-size:18px;font-weight:700;color:#1a201b;">{{ cart.total_price | money }}</span>
  </div>
  <p style="font-size:12px;color:#9ca3af;text-align:center;margin:0 0 14px;">
    Taxes and shipping calculated at checkout
  </p>
  <a
    href="/checkout"
    style="
      display:block;width:100%;
      background:#1a201b;color:#fff;
      text-align:center;
      padding:16px;
      border-radius:16px;
      font-size:14px;font-weight:700;
      text-decoration:none;
      letter-spacing:0.01em;
      transition:background 0.2s,transform 0.15s;
    "
    onmouseover="this.style.background='#0f3f21';this.style.transform='translateY(-1px)'"
    onmouseout="this.style.background='#1a201b';this.style.transform='translateY(0)'"
  >
    Checkout
  </a>
  <a
    href="{{ routes.cart_url }}"
    style="
      display:block;width:100%;
      text-align:center;
      padding:12px;
      border-radius:16px;
      font-size:13px;font-weight:500;
      color:#6b7280;
      text-decoration:none;
      margin-top:8px;
      transition:color 0.2s;
    "
    onmouseover="this.style.color='#1a201b'"
    onmouseout="this.style.color='#6b7280'"
  >
    View full cart →
  </a>
</div>

<div id="cart-drawer-count-inner" style="display:none;">{{ cart.item_count }}</div>

{% schema %}
{
  "name": "Cart Drawer Body"
}
{% endschema %}
