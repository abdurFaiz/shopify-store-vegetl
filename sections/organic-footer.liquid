<footer
  class="w-full relative min-h-[500px] flex flex-col justify-between overflow-hidden mt-20"
  id="Section-{{ section.id }}"
>
  {%- if section.settings.bg_image != blank -%}
    {{
      section.settings.bg_image
      | image_url: width: 2400
      | image_tag: class: 'absolute inset-0 w-full h-full object-cover z-0 pointer-events-none'
    }}
  {%- else -%}
    <img
      src="{{ 'footer.jpg' | file_url }}"
      width="1440"
      height="1080"
      alt="Footer Background"
      class="absolute inset-0 w-full h-full object-cover z-0 pointer-events-none"
    >
  {%- endif -%}

  <div class="flex-1 flex flex-col items-center justify-center pt-32 pb-16 relative z-10 w-full px-4 text-center">
    <h2 class="text-4xl md:text-[54px] font-medium text-[#1a201b] mb-10 tracking-tight">
      {{ section.settings.heading }}
    </h2>

    <a
      href="{{ section.settings.button_link | default: '#' }}"
      class="inline-flex items-center bg-white rounded-full pl-6 pr-1.5 py-1.5 group shadow-sm hover:shadow-md transition-all"
    >
      <span class="text-[#1a201b] text-[14px] font-medium mr-4">{{ section.settings.button_text }}</span>
      <span class="bg-[#0f3f21] text-white w-9 h-9 rounded-full flex items-center justify-center group-hover:bg-[#005000] transition-colors">
        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
          <path d="M9.29 15.88L13.17 12 9.29 8.12a.996.996 0 1 1 1.41-1.41l4.59 4.59c.39.39.39 1.02 0 1.41L10.7 17.3a.996.996 0 0 1-1.41 0c-.38-.39-.39-1.03 0-1.42z"/>
        </svg>
      </span>
    </a>
  </div>

  <div class="w-full px-8 pb-8 relative z-10">
    <p class="text-[10px] text-[#1a201b] tracking-[0.15em] uppercase font-medium">
      &copy; {{ 'now' | date: '%Y' }}
      {{ shop.name }}. ALL RIGHTS RESERVED.
    </p>
  </div>
</footer>

{% schema %}
{
  "name": "Organic Footer CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join us in our growth"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Inquire"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    }
  ],
  "presets": [
    {
      "name": "Organic Footer CTA"
    }
  ]
}
{% endschema %}
