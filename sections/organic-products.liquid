<section
  class="py-12 lg:py-24 bg-white flex flex-col justify-center items-center gap-6 lg:gap-10 mx-auto max-w-screen w-full"
  id="Section-{{ section.id }}"
>
  <div class="max-w-[1300px] mx-auto px-4 lg:px-6 items-center justify-center flex flex-col gap-4 text-center mb-10 lg:mb-12 border-box gsap-fade-up">
    {% if section.settings.subheading != blank %}
      <span class="inline-flex items-center w-fit flex gap-2 text-gray-600 border border-gray-200 px-3.5 py-1.5 rounded-full text-[12px] font-medium tracking-wide mb-6 bg-white shadow-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-[#0f3f21] mr-2"></span>
        {{ section.settings.subheading }}
      </span>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="text-3xl md:text-[46px] leading-tight font-medium text-[#1a201b] tracking-tight">
        {{ section.settings.heading }}
      </h2>
    {% endif %}
  </div>

  <div class="max-w-[1300px] mx-auto px-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12 gsap-stagger-parent">
    {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
      <div class="group flex flex-col gap-4">
        <div class="relative w-full aspect-[4/3] sm:aspect-square rounded-[36px] overflow-hidden mb-5 bg-gray-100 isolate">
          <a href="{{ product.url }}" class="block w-full h-full">
            {% if product.featured_image != blank %}
              {{
                product.featured_image
                | image_url: width: 600
                | image_tag: class: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-700'
              }}
            {% else %}
              <img
                src="{{ 'product-1.png' | file_img_url: 'original' }}"
                width="300"
                height="300"
                alt="product image"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 bg-gray-200"
                loading="lazy"
                fetchpriority="high"
              >
            {% endif %}
          </a>

          <div class="absolute bottom-0 right-0 bg-[#fafbfa] pt-3 pl-3 rounded-tl-[36px] z-10 pointer-events-auto">
            <form method="post" action="{{ routes.cart_add_url }}" class="m-0">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <button
                type="submit"
                class="bg-[#1a201b] text-white w-[56px] h-[56px] flex items-center justify-center rounded-tl-[24px] rounded-br-[24px] rounded-tr-[12px] rounded-bl-[12px] hover:bg-[#0f3f21] hover:text-white transition-colors shadow-md"
              >
                <span class="text-[20px] " data-icon="shopping_cart">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="size-6"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                  </svg>
                </span>
              </button>
            </form>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-6"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
            </svg>
          </div>
        </div>

        <div class="flex justify-between items-start gap-4 px-2">
          <div>
            <h3 class="font-bold text-[18px] text-[#1a201b] leading-tight mb-1.5">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>
            <p class="text-[13px] text-gray-500 leading-snug">
              {{ product.metafields.custom.short_description | default: 'Sweet, juicy, and naturally grown.' }}
            </p>
          </div>
          <span class="font-bold text-[18px] text-[#1a201b] leading-tight whitespace-nowrap">
            {{- product.price | money -}}
          </span>
        </div>
      </div>
    {%- else -%}
      {%- for i in (1..section.settings.products_to_show) -%}
        {% assign index = i | modulo: 6 | plus: 1 %}
        {% assign file_name = 'product-' | append: index | append: '.png' %}

        {% assign titles = 'Beetroot Detox Blend|Strawberry Raspberry Splash|Dragon Fruit Energy|Mango Pineapple Tropical|Carrot Citrus Zest|Green Apple Celery Clear'
          | split: '|'
        %}
        {% assign descriptions = 'Earthy sweetness for a healthy heart.|A berry delicious antioxidant boost.|Exotic, vibrant, and deeply refreshing.|A sip of sunshine in a bottle.|Vitamin-packed immunity booster.|Crisp, cleansing, and ultra-fresh.'
          | split: '|'
        %}

        {% assign array_index = index | minus: 1 %}
        {% assign title = titles[array_index] %}
        {% assign desc = descriptions[array_index] %}

        <div class="group flex flex-col gap-4">
          <div class="relative w-full aspect-[4/3] sm:aspect-square rounded-[36px] overflow-hidden mb-5 bg-gray-100 isolate border border-black/5">
            <a href="#" class="block w-full h-full">
              <img
                src="{{ file_name | file_img_url: 'original' }}"
                width="300"
                height="300"
                alt=""
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 bg-gray-200"
                loading="lazy"
                fetchpriority="high"
              >
            </a>

            <div class="absolute bottom-0 right-0 bg-[#fafbfa] pt-3 pl-3 rounded-tl-[36px] z-10 pointer-events-auto">
              <button class="bg-[#1a201b] text-white w-[56px] h-[56px] flex items-center justify-center rounded-tl-[24px] rounded-br-[24px] rounded-tr-[12px] rounded-bl-[12px] hover:bg-[#0f3f21] hover:text-white transition-colors shadow-md">
                <span class="text-[20px]" data-icon="shopping_cart">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="size-6"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                  </svg>
                </span>
              </button>
            </div>
          </div>

          <div class="flex justify-between items-start gap-4 px-2">
            <div class="flex flex-col gap-1">
              <h3 class="font-bold text-[18px] text-[#1a201b] leading-tight">
                <a href="#">{{ title }}</a>
              </h3>
              <p class="text-[13px] text-gray-500 leading-snug">{{ desc }}</p>
            </div>
            <span class="font-bold text-[18px] text-[#1a201b] leading-tight whitespace-nowrap">$599</span>
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Organic Products",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Small Badge Text",
      "default": "Products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Freshest Picks"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Featured Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Organic Products"
    }
  ]
}
{% endschema %}
