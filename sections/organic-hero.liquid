<section class="bg-white pt-2 pb-6 px-4 lg:py-8 full-width" id="Section-{{ section.id }}">
  <div class="w-full-screen grid grid-cols-1 lg:grid-cols-2 gap-4 min-h-[500px] lg:min-h-[700px]">
    <!-- LEFT COLUMN -->
    <div class="flex flex-col gap-4 lg:gap-6 h-full">
      <!-- Top Big Card -->
      <div class="flex-1 bg-[#0f3f21]/10 rounded-2xl flex flex-col gap-6 items-center justify-center p-8 lg:p-16 text-center shadow-sm">
        {% if section.settings.subheading != blank %}
          <span class="inline-flex items-center text-green-900 bg-green-700/10 px-3 py-1 rounded-full text-sm font-medium tracking-widest uppercase mb-8 backdrop-blur-sm">
            {{ section.settings.subheading }}
          </span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <div class="text-[40px] md:text-[52px] lg:text-[72px] font-medium font-headline leading-[1.05] tracking-tight text-[#0f3f21] mb-8 lg:mb-10">
            {{ section.settings.heading }}
          </div>
        {% endif %}
        {% if section.settings.button_label != blank %}
          <a
            {% if section.settings.button_link != blank %}
              href="{{ section.settings.button_link }}"
            {% endif %}
            class="inline-flex items-center gap-3 bg-[#0f3f21] text-white pl-8 pr-0.5 py-0.5 rounded-full font-semibold text-base hover:bg-[#72d342] transition-all active:scale-95"
          >
            {{ section.settings.button_label }}
            <span class="bg-white rounded-full w-12 h-12 flex items-center justify-center shadow-sm">
              <span class="material-symbols-outlined text-[#0f3f21] text-base" data-icon="call_made">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="size-4"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
                </svg>
              </span>
            </span>
          </a>
        {% endif %}
      </div>

      <!-- Bottom Small Cards Row -->
      <div class="flex flex-col md:grid md:grid-cols-[3fr_2fr] gap-4 lg:gap-6 h-auto md:h-[240px] lg:h-[300px]">
        <!-- Bottom Left: Farm Map -->
        <div class="h-[240px] md:h-auto rounded-2xl overflow-hidden relative shadow-sm bg-gray-100 group cursor-pointer">
          {% if section.settings.sub_image != blank %}
            <img
              srcset="
                {{ section.settings.sub_image | image_url: width: 400 }} 400w,
                {{ section.settings.sub_image | image_url: width: 600 }} 600w,
                {{ section.settings.sub_image | image_url: width: 800 }} 800w
              "
              src="{{ section.settings.sub_image | image_url: width: 600 }}"
              alt="{{ section.settings.card_1_title }}"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 40vw"
              loading="eager"
              fetchpriority="auto"
              width="800"
              height="600"
            >
          {% else %}
            <img
              srcset="
                {{ 'supprt-hero-img.png' | file_img_url: '400x' }} 400w,
                {{ 'supprt-hero-img.png' | file_img_url: '600x' }} 600w,
                {{ 'supprt-hero-img.png' | file_img_url: '800x' }} 800w
              "
              src="{{ 'supprt-hero-img.png' | file_url }}"
              alt="Hero Image"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100"
              sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 40vw"
              loading="eager"
              fetchpriority="auto"
              width="800"
              height="600"
            >
          {% endif %}
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="bg-white/20 backdrop-blur-sm px-3 py-2 rounded-2xl shadow-xl text-center pointer-events-auto hover:-translate-y-1 transition-transform">
              <p class="text-[13px] font-bold text-white mb-0.5">🍓 {{ section.settings.card_1_title }}</p>
              <p class="text-[10px] text-white">{{ section.settings.card_1_subtitle }}</p>
            </div>
          </div>
        </div>

        <!-- Bottom Right: Happy Customer / Fruit -->
        <div class="h-[240px] md:h-auto rounded-[32px] overflow-hidden relative shadow-sm bg-[#6fac2a] isolate">
          {% if section.settings.sub_image_2 != blank %}
            <img
              srcset="
                {{ section.settings.sub_image_2 | image_url: width: 400 }} 400w,
                {{ section.settings.sub_image_2 | image_url: width: 600 }} 600w,
                {{ section.settings.sub_image_2 | image_url: width: 800 }} 800w
              "
              src="{{ section.settings.sub_image_2 | image_url: width: 600 }}"
              alt="Fruit Basket"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
              sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 40vw"
              loading="eager"
              fetchpriority="auto"
              width="600"
              height="600"
            >
          {% else %}
            <img
              srcset="
                {{ 'supprt-hero-img-2.png' | file_img_url: '400x' }} 400w,
                {{ 'supprt-hero-img-2.png' | file_img_url: '600x' }} 600w,
                {{ 'supprt-hero-img-2.png' | file_img_url: '800x' }} 800w
              "
              src="{{ 'supprt-hero-img-2.png' | file_url }}"
              alt="Hero Image"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100"
              sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 40vw"
              loading="lazy"
              fetchpriority="auto"
              width="600"
              height="600"
            >
          {% endif %}

          <!-- Top Left Cutout -->
          <div class="absolute top-0 left-0 bg-white rounded-br-[24px] rounded-tl-[32px] pt-4 pl-4 pr-5 pb-3 z-10 pointer-events-auto">
            <div class="flex -space-x-2 mb-2 items-center">
              <div class="w-8 h-8 rounded-full overflow-hidden border-[2px] border-white shadow-sm">
                <img
                  srcset="                    {{ 'avatar-1.jpg' | asset_url }} 100w"
                  src="{{ 'avatar-1.jpg' | asset_url }}"
                  class="w-full h-full object-cover"
                  alt="Customer"
                  width="32"
                  height="32"
                  loading="lazy"
                >
              </div>
              <div class="w-8 h-8 rounded-full overflow-hidden border-[2px] border-white shadow-sm">
                <img
                  srcset="                    {{ 'avatar-2.jpg' | asset_url }} 100w"
                  src="{{ 'avatar-2.jpg' | asset_url }}"
                  class="w-full h-full object-cover"
                  alt="Customer"
                  width="32"
                  height="32"
                  loading="lazy"
                >
              </div>
              <div class="w-8 h-8 rounded-full overflow-hidden border-[2px] border-white shadow-sm">
                <img
                  srcset="                    {{ 'avatar-3.jpg' | asset_url }} 100w"
                  src="{{ 'avatar-3.jpg' | asset_url }}"
                  class="w-full h-full object-cover"
                  alt="Customer"
                  width="32"
                  height="32"
                  loading="lazy"
                >
              </div>
              <div class="w-8 h-8 flex items-center justify-center rounded-full bg-[#0f3f21] border-[2px] border-white text-[11px] text-white font-bold z-10">
                5k
              </div>
            </div>
            <span class="text-[14px] font-medium text-gray-800 tracking-tight block ml-1">
              {{- section.settings.card_2_title -}}
            </span>
            <svg class="absolute top-0 -right-[20px] w-[20px] h-[20px] fill-white" viewBox="0 0 20 20">
              <path d="M0,0 H20 A20,20 0 0,0 0,20 Z" />
            </svg>
            <svg class="absolute -bottom-[20px] left-0 w-[20px] h-[20px] fill-white" viewBox="0 0 20 20">
              <path d="M0,0 H20 A20,20 0 0,0 0,20 Z" />
            </svg>
          </div>

          <!-- Bottom Right Cutout -->
          <div class="absolute bottom-0 right-0 bg-white rounded-tl-[24px] rounded-br-[32px] pt-4 pl-5 pr-4 pb-4 z-10 pointer-events-auto">
            <p class="text-[14px] font-medium leading-[1.3] text-gray-600 tracking-tight text-left max-w-[120px]">
              {{ section.settings.card_3_title | replace: ' and ', '<br> and ' }}
            </p>
            <svg class="absolute -top-[20px] right-0 w-[20px] h-[20px] fill-white" viewBox="0 0 20 20">
              <path d="M20,20 H0 A20,20 0 0,0 20,0 Z" />
            </svg>
            <svg class="absolute bottom-0 -left-[20px] w-[20px] h-[20px] fill-white" viewBox="0 0 20 20">
              <path d="M20,20 H0 A20,20 0 0,0 20,0 Z" />
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT COLUMN -->
    <div class="rounded-[32px] lg:rounded-2xl overflow-hidden relative shadow-sm h-full min-h-[500px]">
      {% if section.settings.image != blank %}
        <img
          srcset="
            {{ section.settings.image | image_url: width: 600 }} 600w,
            {{ section.settings.image | image_url: width: 900 }} 900w,
            {{ section.settings.image | image_url: width: 1200 }} 1200w
          "
          src="{{ section.settings.image | image_url: width: 900 }}"
          alt="Hero Image"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000"
          loading="eager"
          fetchpriority="high"
          width="1200"
          height="630"

          style="height: 100%;"
        >
      {% else %}
        <img
          srcset="
            {{ 'hero-img.png' | file_img_url: '600x' }}  600w,
            {{ 'hero-img.png' | file_img_url: '900x' }}  900w,
            {{ 'hero-img.png' | file_img_url: '1200x' }} 1200w
          "
          src="{{ 'hero-img.png' | file_img_url: '900x' }}"
          alt="Hero Image"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100"
          loading="eager"
          fetchpriority="high"
          width="1200"
          height="630"
          sizes="(max-width: 1024px) 100vw, 60vw"
        >
      {% endif %}

      <div class="absolute bottom-2 left-2">
        <div class="bg-white px-5 py-3 rounded-2xl flex items-center gap-3 hover:-translate-y-1 transition-transform cursor-pointer">
          <span class="text-sm font-medium text-gray-800">{{ section.settings.card_3_subtitle }}</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Organic Hero",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Est. 1998"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Fresh. Organic.<br>Sustainable.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now Our Product"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image (Farmer)"
    },
    {
      "type": "image_picker",
      "id": "sub_image",
      "label": "Bottom Left Image (Farm Aerial)"
    },
    {
      "type": "image_picker",
      "id": "sub_image_2",
      "label": "Bottom Right Image (Fruit Basket)"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Card 1 Title",
      "default": "Strawberry Field"
    },
    {
      "type": "text",
      "id": "card_1_subtitle",
      "label": "Card 1 Subtitle",
      "default": "Collingwood VIC 3066 AU"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Card 2 Title",
      "default": "+Happy Customer"
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Card 3 Title",
      "default": "100% Authentic and tasty Fruits"
    },
    {
      "type": "text",
      "id": "card_3_subtitle",
      "label": "Card 3 Subtitle",
      "default": "Organic Fruits 🍎"
    }
  ],
  "presets": [
    {
      "name": "Organic Hero"
    }
  ]
}
{% endschema %}
