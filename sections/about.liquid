<div class="about-page bg-white full-width pt-6 lg:pt-8">
  {% comment %} Hero Section {% endcomment %}
  <section class="relative rounded-[32px] mx-auto max-w-full h-[600px] lg:h-[780px]">
    <div class="absolute top-0 bottom-0 left-4 right-4 overflow-hidden rounded-[32px]">
      {% if section.settings.hero_image %}
        {{
          section.settings.hero_image
          | image_url: width: 2000
          | image_tag: class: 'w-full h-full object-cover', loading: 'eager'
        }}
      {% else %}
        {{
          images['hero-about.jpg']
          | image_url: width: 1440
          | image_tag:
            class: 'w-full h-full rounded-[32px] object-cover transition-transform duration-1000 ',
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '100vw',
            alt: 'Hero Image',
            style: 'height:100%;'
        }}
      {% endif %}
      <div class="absolute  inset-0 bg-gradient-to-r  rounded-[32px] from-black/60 to-black/0"></div>
    </div>

    <div class="relative h-full w-full px-10 py-8 flex flex-col gap-6 justify-end">
      <div class="flex flex-col gap-4">
        {% if section.settings.hero_badge %}
          <span class="inline-flex items-center text-white border border-white/10 px-4 py-2 rounded-full text-sm font-medium tracking-wide bg-[#1a201b]/65 backdrop-blur-md w-fit">
            {{ section.settings.hero_badge }}
          </span>
        {% endif %}

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-medium text-white max-w-3xl leading-tight">
          {{ section.settings.hero_heading | default: 'From Our Soil to Your Glass. Pure & Chemical-Free.' }}
        </h1>

        {% if section.settings.hero_subheading %}
          <p class="text-lg md:text-xl text-white/90 max-w-2xl">
            {{
              section.settings.hero_subheading
              | default: 'Experience the difference of farm-fresh goodness with our premium range of fruits and vegetables. Grown with care and delivered with love.'
            }}
          </p>
        {% endif %}
      </div>

      {% if section.settings.hero_button_text %}
        <a
          href="{{ section.settings.hero_button_link | default: '#' }}"
          class="inline-flex items-center text-white gap-3 bg-[#0f3f21] hover:bg-[#0f3f21]/80 font-medium pr-1 pl-4 py-1 rounded-full transition-colors w-fit"
        >
          {{ section.settings.hero_button_text }}
          <div class="bg-white rounded-full w-12 h-12 flex items-center justify-center">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-4 text-[#1a201b]"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </div>
        </a>
      {% endif %}
    </div>

    {% comment %} Hero card - bottom right with product image slider {% endcomment %}
    {% assign card_slides = section.blocks | where: 'type', 'card_image' %}
    <div class="absolute bottom-10 right-10 w-60 z-10 hidden lg:block">
      <div class="bg-[#1a201b]/65 backdrop-blur-md rounded-2xl overflow-hidden">
        {% comment %} Image slider area {% endcomment %}
        <div class="relative" id="about-hero-card">
          <div class="about-card-track p-1.5 relative overflow-hidden h-44">
            {% if card_slides.size > 0 %}
              {% for block in card_slides %}
                <div class="about-card-slide absolute rounded-2xl p-1.5 inset-0 transition-opacity duration-500 {% if forloop.first %}opacity-100{% else %}opacity-0 pointer-events-none{% endif %}">
                  {% if block.settings.card_image %}
                    {{
                      block.settings.card_image
                      | image_url: width: 600
                      | image_tag: class: 'w-full h-full object-cover'
                    }}
                  {% else %}
                    {{
                      images['product-2.png']
                      | image_url: width: 1440
                      | image_tag:
                        class: 'w-full h-full rounded-2xl object-cover transition-transform duration-1000 ',
                        loading: 'eager',
                        fetchpriority: 'high',
                        sizes: '100vw',
                        alt: 'Hero Image'
                    }}
                  {% endif %}
                </div>
              {% endfor %}
            {% else %}
              {{
                images['supprt-hero-img.png']
                | image_url: width: 1440
                | image_tag:
                  class: 'w-full h-full rounded-2xl object-cover transition-transform duration-1000 ',
                  loading: 'eager',
                  fetchpriority: 'high',
                  sizes: '100vw',
                  alt: 'Hero Image'
              }}
            {% endif %}
          </div>
        </div>

        {% comment %} Card text content {% endcomment %}
        <div class="p-4">
          {% if section.settings.hero_card_label %}
            <div class="flex items-center gap-2 mb-2">
              <span class="w-2 h-2 rounded-full bg-[#a3d977] flex-shrink-0"></span>
              <span class="text-white/70 text-xs font-medium uppercase tracking-wider">
                {{- section.settings.hero_card_label -}}
              </span>
            </div>
          {% endif %}

          {% if section.settings.hero_card_text %}
            <p class="text-white/80 text-sm leading-relaxed mb-4">{{ section.settings.hero_card_text }}</p>
          {% endif %}
        </div>
      </div>
    </div>

    {% comment %} Bottom center label shape overlapping next section {% endcomment %}
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 z-[999]">
      <div class="bg-white rounded-[32px] px-10 md:px-16 lg:px-20 lg:py-10 py-5 flex items-center gap-2 whitespace-nowrap">
        <span class="text-xl md:text-5xl font-medium text-[#1a201b]">Get to Know</span>
        <span class="text-xl md:text-5xl font-medium text-[#a3d977]">Us</span>
      </div>
    </div>
  </section>

  {% comment %} Mission Statement - organic floating images layout {% endcomment %}
  <section
    class="py-12 lg:py-24 bg-[#f4f7f5] overflow-hidden relative full-width flex justify-center items-center"
    id="Section-{{ section.id }}"
  >
    <div class="max-w-[1440px] mx-auto px-4 lg:px-6 grid grid-cols-1 lg:grid-cols-[1fr_2fr_1fr] gap-8 lg:gap-6 items-center relative z-10 w-full min-h-[500px]">
      <!-- Left Images (Grid on mobile, Absolute on LG) -->
      <div class="lg:absolute left-0 top-0 bottom-0 w-full lg:w-[240px] z-0 pointer-events-none flex lg:block flex-row justify-center gap-4 h-[200px] lg:h-auto overflow-hidden lg:overflow-visible">
        <!-- Top Left Image -->
        <div class="lg:absolute top-[5%] lg:left-[20px] w-1/2 max-w-[180px] lg:w-[180px] h-full lg:h-[240px] rounded-[24px] overflow-hidden shadow-sm border border-black/5 pointer-events-auto hover:scale-105 transition-transform duration-500">
          {% if section.settings.image_1 != blank %}
            {{ section.settings.image_1 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
          {% else %}
            {{
              images['about-1.jpg']
              | image_url: width: 400
              | image_tag:
                class: 'w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100',
                loading: 'eager',
                fetchpriority: 'auto',
                width: 300,
                height: 300,
                alt: 'About Image 1',
                style: 'height:100%;'
            }}
          {% endif %}
        </div>
        <!-- Bottom Left Image -->
        <div class="lg:absolute bottom-[0%] lg:left-[60px] w-1/2 max-w-[200px] lg:w-[200px] h-full lg:h-[260px] rounded-[24px] overflow-hidden shadow-sm border border-black/5 pointer-events-auto hover:scale-105 transition-transform duration-500">
          {% if section.settings.image_3 != blank %}
            {{ section.settings.image_3 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
          {% else %}
            {{
              images['about-2.png']
              | image_url: width: 400
              | image_tag:
                class: 'w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100',
                loading: 'eager',
                fetchpriority: 'auto',
                width: 300,
                height: 300,
                alt: 'About Image 2',
                style: 'height:100%;'
            }}
          {% endif %}
        </div>
      </div>

      <!-- Right Images (Absolute on LG) -->
      <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[240px] z-0 pointer-events-none">
        <!-- Top Right Image -->
        <div class="absolute top-[10%] right-0 xl:right-[0px] w-[220px] h-[280px] rounded-[24px] overflow-hidden shadow-sm border border-black/5 pointer-events-auto hover:scale-105 transition-transform duration-500">
          {% if section.settings.image_2 != blank %}
            {{ section.settings.image_2 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
          {% else %}
            {{
              images['about-2.png']
              | image_url: width: 400
              | image_tag:
                class: 'w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100',
                loading: 'eager',
                fetchpriority: 'auto',
                width: 300,
                height: 300,
                alt: 'About Image 2',
                style: 'height:100%;'
            }}
          {% endif %}
        </div>
        <!-- Bottom Right Image -->
        <div class="absolute bottom-[-10%] right-[40px] xl:right-[100px] w-[180px] h-[220px] rounded-[24px] overflow-hidden shadow-sm border border-black/5 pointer-events-auto hover:scale-105 transition-transform duration-500">
          {% if section.settings.image_4 != blank %}
            {{ section.settings.image_4 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
          {% else %}
            {{
              images['about-3.png']
              | image_url: width: 400
              | image_tag:
                class: 'w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100',
                loading: 'eager',
                fetchpriority: 'auto',
                width: 300,
                height: 300,
                alt: 'About Image 3',
                style: 'height:100%;'
            }}
          {% endif %}
        </div>
      </div>

      <!-- Center Content -->
      <div class="lg:col-start-2 lg:col-span-1 flex flex-col gap-6 items-center justify-center text-center z-10 w-full max-w-[700px] mx-auto pt-10 pb-10">
        {% if section.settings.mission_badge != blank %}
          <span class="inline-flex items-center gap-2 text-gray-600 border border-gray-200 px-3.5 py-1.5 rounded-full text-[12px] font-medium tracking-wide mb-6 bg-white shadow-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-[#0f3f21] mr-2"></span>
            {{ section.settings.mission_badge }}
          </span>
        {% endif %}

        {% if section.settings.mission_heading != blank %}
          <div class="custom-about-heading text-[26px] md:text-[34px] leading-[1.4] text-gray-800 mb-6 font-medium tracking-tight">
            {{ section.settings.mission_heading }}
          </div>
        {% endif %}

        {% if section.settings.mission_text != blank %}
          <div class="text-[13px] md:text-[15px] leading-relaxed text-gray-700 max-w-[560px] mb-8">
            {{ section.settings.mission_text }}
          </div>
        {% endif %}
      </div>

      <!-- Mobile Images Grid -->
      <div class="grid grid-cols-2 gap-4 lg:hidden mt-8 w-full px-4">
        <div class="h-48 rounded-[24px] overflow-hidden shadow-sm">
          {% if section.settings.image_1 != blank %}
            {{ section.settings.image_1 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
          {% else %}
            {{
              images['about-4.png']
              | image_url: width: 400
              | image_tag:
                class: 'w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100',
                loading: 'eager',
                fetchpriority: 'auto',
                width: 300,
                height: 300,
                alt: 'About Image 4',
                style: 'height:100%;'
            }}
          {% endif %}
        </div>
        <div class="h-56 rounded-[24px] overflow-hidden mt-8 shadow-sm">
          {% if section.settings.image_2 != blank %}
            {{ section.settings.image_2 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
          {% else %}
            {{
              images['about-2.png']
              | image_url: width: 400
              | image_tag:
                class: 'w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100',
                loading: 'eager',
                fetchpriority: 'auto',
                width: 300,
                height: 300,
                alt: 'About Image 2',
                style: 'height:100%;'
            }}
          {% endif %}
        </div>
        <div class="h-64 rounded-[24px] overflow-hidden -mt-4 shadow-sm">
          {% if section.settings.image_3 != blank %}
            {{ section.settings.image_3 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
          {% else %}
            {{
              images['about-1.jpg']
              | image_url: width: 400
              | image_tag:
                class: 'w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100',
                loading: 'eager',
                fetchpriority: 'auto',
                width: 300,
                height: 300,
                alt: 'About Image 1',
                style: 'height:100%;'
            }}
          {% endif %}
        </div>
        <div class="h-48 rounded-[24px] overflow-hidden mt-4 shadow-sm">
          {% if section.settings.image_4 != blank %}
            {{ section.settings.image_4 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
          {% else %}
            {{
              images['about-3.png']
              | image_url: width: 400
              | image_tag:
                class: 'w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100',
                loading: 'eager',
                fetchpriority: 'auto',
                width: 300,
                height: 300,
                alt: 'About Image 3',
                style: 'height:100%;'
            }}
          {% endif %}
        </div>
      </div>
    </div>
  </section>

  {% comment %} Blog highlight section {% endcomment %}
  <section class="pb-16 lg:pb-24 bg-[#0f3f21] text-white">
    {% if section.settings.hero_image %}
      {{
        section.settings.hero_image
        | image_url: width: 2000
        | image_tag: class: 'w-full h-[500px] object-cover', loading: 'eager'
      }}
    {% else %}
      {{
        images['blog-section.jpg']
        | image_url: width: 1440
        | image_tag:
          class: 'w-full h-[780px] pb-20 object-cover transition-transform duration-1000',
          loading: 'lazy',
          fetchpriority: 'low',
          sizes: '100vw',
          width: 1440,
          height: 1440,
          alt: 'Blog Section'
      }}
    {% endif -%}

    <div class="max-w-full mx-auto px-[48px]">
      <div class="flex flex-col gap-24 items-start">
        <div class="max-w-full w-full flex flex-col md:flex-row justify-between item-end">
          <div class="flex flex-col gap-4">
            {% if section.settings.blog_badge %}
              <span class="inline-flex items-center text-[#d4f2c1] w-fit border border-white/20 px-3.5 py-2 rounded-full text-sm font-medium Capitalize mb-1 bg-white/10">
                {{ section.settings.blog_badge }}
              </span>
            {% endif %}

            <h2 class="text-4xl md:text-5xl xl:text-6xl font-medium mb-6 max-w-3xl">
              {{ section.settings.blog_heading | default: 'Our farming and market gardening blog' }}
            </h2>
          </div>

          <div class="flex flex-col gap-3">
            <p class="text-base md:text-lg text-white/80 leading-relaxed mb-6 max-w-xl">
              {{
                section.settings.blog_subheading
                | default: 'Reliable tools, techniques and advice to help you take the next step in your agrarian adventures.'
              }}
            </p>

            {% if section.settings.blog_button_text %}
              <a
                href="{{ section.settings.blog_button_link | default: '#' }}"
                class="inline-flex items-center justify-center rounded-full bg-[#f8d74a] w-fit text-[#1a201b] font-semibold px-8 py-4 shadow-lg shadow-black/10 hover:bg-[#f1ce36] transition-colors"
              >
                {{ section.settings.blog_button_text }}
              </a>
            {% endif %}
          </div>
        </div>

        <div class="grid gap-6 sm:grid-cols-4">
          {% for block in section.blocks %}
            {% if block.type == 'blogcard' %}
              <article class="group rounded-[32px] text-[#1a201b] transition-transform duration-300 hover:-translate-y-1">
                {% if block.settings.card_image %}
                  {{
                    block.settings.card_image
                    | image_url: width: 900
                    | image_tag: class: 'w-full h-72 rounded-3xl object-cover', alt: block.settings.card_image_alt
                    | default: 'Blog image'
                  }}
                {% else %}
                  <div class="h-72  rounded-3xl bg-white"></div>
                {% endif %}

                <div class="p-6">
                  {% if block.settings.card_category %}
                    <p class="text-sm capitalize text-white mb-3 font-medium">
                      {{ block.settings.card_category }}
                    </p>
                  {% endif %}

                  <h3 class="text-xl text-white font-semibold mb-3 leading-snug">{{ block.settings.card_title }}</h3>

                  {% if block.settings.card_url %}
                    <a
                      href="{{ block.settings.card_url }}"
                      class="inline-flex items-center gap-2 text-sm font-semibold text-white"
                    >
                      {{ block.settings.card_button_text | default: 'Read more' }}
                      <svg
                        class="w-4 h-4"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M5 12h14"></path>
                        <path d="m13 6 6 6-6 6"></path>
                      </svg>
                    </a>
                  {% endif %}
                </div>
              </article>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

  {% comment %} Features Section - Dark Background with Metrics Layout and Image {% endcomment %}
  <section class="bg-white text-white w-full">
    <div class="w-full">
      <div class="grid lg:grid-cols-2 gap-0">
        <div class="flex flex-col justify-center overflow-hidden">
          {% if section.settings.features_image %}
            {{
              section.settings.features_image
              | image_url: width: 1000
              | image_tag: class: 'w-full h-full object-cover'
            }}
          {% else %}
            {{
              images['supprt-hero-img.png']
              | image_url: width: 1000
              | image_tag:
                class: 'w-full h-full object-cover transition-transform duration-1000 bg-gray-100',
                loading: 'lazy',
                fetchpriority: 'low',
                sizes: '50vw',
                alt: 'Features Image'
            }}
          {% endif %}
        </div>
        <div class="px-6 pb-12 lg:px-12 flex flex-col justify-center space-y-8">
          <h2 class="text-3xl md:text-5xl text-[#0f3f21] font-medium py-14 leading-tight max-w-lg">
            {{ section.settings.features_heading | default: 'Field-Tested. Farmer-Approved.' }}
          </h2>

          <!-- Feature 1 -->
          <div class="flex gap-12 items-start justify-between pb-8 border-b border-[#0f3f21]/10">
            <div class="flex-shrink-0">
              <div class="text-6xl md:text-7xl font-medium text-[#a3d977]">4</div>
            </div>
            <div class="flex-1 max-w-xs pt-2">
              <p class="text-base text-[#0f3f21] leading-relaxed">CONTINENTS TESTED</p>
            </div>
          </div>

          <!-- Feature 2 -->
          <div class="flex gap-12 items-start justify-between pb-8 border-b border-[#0f3f21]/10">
            <div class="flex-shrink-0">
              <div class="text-6xl md:text-7xl font-medium text-[#a3d977]">100x</div>
            </div>
            <div class="flex-1 max-w-xs pt-2">
              <p class="text-base text-[#0f3f21] leading-relaxed">LOWER TRANSPORT COST</p>
            </div>
          </div>

          <!-- Feature 3 -->
          <div class="flex gap-12 items-start justify-between pb-8 border-b border-[#0f3f21]/10">
            <div class="flex-shrink-0">
              <div class="text-6xl md:text-7xl font-medium text-[#a3d977]">0.5 ton</div>
            </div>
            <div class="flex-1 max-w-xs pt-2">
              <p class="text-base text-[#0f3f21] leading-relaxed">CO₂ SAVED PER ACRE – AT NO EXTRA COST</p>
            </div>
          </div>

          <!-- Feature 4 -->
          <div class="flex gap-12 items-start justify-between">
            <div class="flex-shrink-0">
              <div class="text-6xl md:text-7xl font-medium text-[#a3d977]">≥5x</div>
            </div>
            <div class="flex-1 max-w-xs pt-2">
              <p class="text-base text-[#0f3f21] leading-relaxed">RETURN* ON EVERY DOLLAR INVESTED</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {% comment %} Products Section {% endcomment %}
  <section class="py-12 lg:py-40 bg-white flex flex-col gap-6 lg:gap-10 justify-center item-center w-full">
    <div class=" mx-auto px-4 lg:px-6 text-center ">
      <h2 class="text-3xl md:text-5xl leading-tight font-medium text-[#0f3f21] tracking-tight">
        {{ section.settings.products_heading | default: 'Our Products' }}
      </h2>
    </div>

    <div class="max-w-full mx-auto px-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12">
      {% for product in collections.all.products limit: 3 %}
        <div class="group flex flex-col gap-4">
          <div class="relative w-full aspect-[4/3] sm:aspect-square rounded-[36px] overflow-hidden mb-5 bg-gray-100 isolate">
            <a href="{{ product.url }}" class="block w-full h-full">
              {% if product.featured_image %}
                {{
                  product.featured_image
                  | image_url: width: 600
                  | image_tag:
                    class: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-700',
                    loading: 'lazy'
                }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-gray-200' }}
              {% endif %}
            </a>

            {% if product.compare_at_price > product.price %}
              <div class="absolute top-4 left-4 bg-[#d32f2f] text-white px-3 py-1 rounded-full text-xs font-semibold">
                {{ 'products.sale' | t }}
              </div>
            {% endif %}

            {% unless product.available %}
              <div class="absolute top-4 left-4 bg-gray-600 text-white px-3 py-1 rounded-full text-xs font-semibold">
                {{ 'products.sold_out' | t }}
              </div>
            {% endunless %}

            <div class="absolute bottom-0 right-0 bg-[#fafbfa] pt-3 pl-3 rounded-tl-[36px] z-10 pointer-events-auto">
              <form method="post" action="{{ routes.cart_add_url }}" class="m-0">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button
                  type="submit"
                  class="bg-[#1a201b] text-white w-[56px] h-[56px] flex items-center justify-center rounded-tl-[24px] rounded-br-[24px] rounded-tr-[12px] rounded-bl-[12px] hover:bg-[#0f3f21] transition-colors shadow-md"
                  {% unless product.available %}
                    disabled
                  {% endunless %}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="size-6"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                  </svg>
                </button>
              </form>
              <svg class="absolute -top-[24px] right-0 w-[24px] h-[24px] fill-[#fafbfa]" viewBox="0 0 24 24">
                <path d="M24,24 H0 A24,24 0 0,0 24,0 Z" />
              </svg>
              <svg class="absolute bottom-0 -left-[24px] w-[24px] h-[24px] fill-[#fafbfa]" viewBox="0 0 24 24">
                <path d="M24,24 H0 A24,24 0 0,0 24,0 Z" />
              </svg>
            </div>
          </div>

          <div class="flex justify-between items-start gap-4 px-2">
            <div class="flex flex-col gap-1">
              {% if section.settings.show_vendor and product.vendor %}
                <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">{{ product.vendor }}</p>
              {% endif %}
              <h3 class="font-bold text-[18px] text-[#1a201b] leading-tight mb-1.5">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>
              <p class="text-[13px] text-gray-500 leading-snug">
                {{ product.description | strip_html | truncate: 60 }}
              </p>
            </div>
            <div class="text-right whitespace-nowrap">
              {% if product.compare_at_price > product.price %}
                <span class="font-bold text-[18px] text-[#d32f2f] leading-tight block">
                  {{ product.price | money }}
                </span>
                <span class="text-[14px] text-gray-400 line-through">
                  {{ product.compare_at_price | money }}
                </span>
              {% else %}
                <span class="font-bold text-[18px] text-[#1a201b] leading-tight">
                  {{ product.price | money }}
                </span>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </section>

  {% comment %} Testimonials Section {% endcomment %}
  {% render 'organic-testimonials',
    heading: section.settings.testimonials_heading
  %}

  {% comment %} Newsletter/Community Section {% endcomment %}
  {% render 'organic-newsletter',
    heading: section.settings.cta_heading,
    description: section.settings.cta_text,
    button_text: section.settings.cta_button_primary_text,
    button_link: section.settings.cta_button_primary_link,
    large_number: section.settings.cta_large_number,
    number_color: section.settings.cta_number_color,
    avatar_1: section.settings.cta_avatar_1,
    avatar_2: section.settings.cta_avatar_2,
    avatar_3: section.settings.cta_avatar_3,
    avatar_4: section.settings.cta_avatar_4
  %}
</div>

