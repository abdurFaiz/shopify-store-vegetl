<section
  class="py-12 lg:py-24 bg-[#f4f7f5] full-width w-full mx-auto flex flex-col items-center gap-6 lg:gap-10"
  id="Section-{{ section.id }}"
>
  <div class="max-w-[1300px] mx-auto px-4 lg:px-6 text-center flex items-center justify-center flex-col gap-2 mb-10 lg:mb-16">
    {% if section.settings.subheading != blank %}
      <span class="inline-flex gap-2 items-center w-fit text-gray-600 border border-gray-200 px-3.5 py-1.5 rounded-full text-[12px] font-medium tracking-wide mb-6 bg-white shadow-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-[#0f3f21] mr-2"></span>
        {{ section.settings.subheading }}
      </span>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="text-3xl lg:text-[48px] leading-tight font-normal text-[#1a201b] tracking-tight">
        {{ section.settings.heading }}
      </h2>
    {% endif %}
  </div>

  <div class="max-w-[1300px] mx-auto px-4 xl:px-6 grid grid-cols-1 lg:grid-cols-2 gap-4">
    <!-- LEFT ALIGNED: Large Image with Cutout Badge -->
    <div class="relative w-full h-[400px] lg:h-auto min-h-[400px] lg:min-h-[600px] rounded-[32px] lg:rounded-[40px] overflow-hidden isolate border border-black/5">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag: class: 'w-full h-full object-cover absolute inset-0 z-0'
        }}
      {% else %}
        <img
          src="{{ 'whyus.png' | file_img_url: 'original' }}"
          alt="Hero Image"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100"
          loading="lazy"
          fetchpriority="low"
          height="300"
          width="300"
        >
      {% endif %}

      <!-- Squircle Cutout Wrapper -->
      <div class="absolute bottom-0 left-0 bg-[#f4f7f5] pt-2.5 pr-2.5 rounded-tr-[44px] z-10 pointer-events-auto">
        <!-- SVG Inverted Corners -->
        <svg class="absolute -top-[28px] left-0 w-[28px] h-[28px] fill-[#f4f7f5]" viewBox="0 0 24 24">
          <path d="M 24,24 A 24,24 0 0 1 0,0 L 0,24 Z" />
        </svg>
        <svg class="absolute bottom-0 -right-[28px] w-[28px] h-[28px] fill-[#f4f7f5]" viewBox="0 0 24 24">
          <path d="M 24,24 A 24,24 0 0 1 0,0 L 0,24 Z" />
        </svg>

        <!-- White Floating Badge Content -->
        <div class="bg-white rounded-[32px] rounded-bl-[24px] p-6 shadow-sm min-w-[220px]">
          <div class="flex items-center -space-x-3 mb-4">
            <img
              src="{{ 'avatar-1.jpg' | asset_url }}"
              alt="Avatar"
              width="100"
              height="100"
              class="w-[40px] h-[40px] rounded-full border-[3px] border-white object-cover bg-gray-100 z-30"
            >
            <img
              src="{{ 'avatar-2.jpg' | asset_url }}"
              alt="Avatar"
              width="100"
              height="100"
              class="w-[40px] h-[40px] rounded-full border-[3px] border-white object-cover bg-gray-100 z-20"
            >
            <img
              src="{{ 'avatar-3.jpg' | asset_url }}"
              alt="Avatar"
              width="100"
              height="100"
              class="w-[40px] h-[40px] rounded-full border-[3px] border-white object-cover bg-gray-100 z-10"
            >
            <div class="w-[40px] h-[40px] rounded-full border-[3px] border-white bg-[#0f3f21] text-white text-[11px] font-bold flex items-center justify-center z-0">
              {{ section.settings.floating_badge_stat }}
            </div>
          </div>
          <p class="font-bold text-[16px] text-[#1a201b] leading-tight max-w-[150px]">
            {{ section.settings.floating_badge_title }}
          </p>
        </div>
      </div>
    </div>

    <!-- RIGHT ALIGNED: Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 h-full">
      {% for block in section.blocks %}
        <div
          class="bg-white rounded-[40px] p-6 flex justify-between flex-col group transition-all hover:shadow-xl hover:shadow-black/5 hover:-translate-y-1"
          {{ block.shopify_attributes }}
        >
          <div class="flex flex-col gap-6">
            <div class="w-[56px] h-[56px] bg-[#f4f7f5] text-green-800 rounded-[24px] rounded-bl-[8px] flex items-center justify-center mb-10 shrink-0 border border-green-900/5">
              {% case block.settings.icon %}
                {% when 'eco' %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="size-6"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12.75 3.03v.568c0 .334.148.65.405.864l1.068.89c.442.369.535 1.01.216 1.49l-.51.766a2.25 2.25 0 0 1-1.161.886l-.143.048a1.107 1.107 0 0 0-.57 1.664c.369.555.169 1.307-.427 1.605L9 13.125l.423 1.059a.956.956 0 0 1-1.652.928l-.679-.906a1.125 1.125 0 0 0-1.906.172L4.5 15.75l-.612.153M12.75 3.031a9 9 0 0 0-8.862 12.872M12.75 3.031a9 9 0 0 1 6.69 14.036m0 0-.177-.529A2.25 2.25 0 0 0 17.128 15H16.5l-.324-.324a1.453 1.453 0 0 0-2.328.377l-.036.073a1.586 1.586 0 0 1-.982.816l-.99.282c-.55.157-.894.702-.8 1.267l.073.438c.08.474.49.821.97.821.846 0 1.598.542 1.865 1.345l.215.643m5.276-3.67a9.012 9.012 0 0 1-5.276 3.67m0 0a9 9 0 0 1-10.275-4.835M15.75 9c0 .896-.393 1.7-1.016 2.25" />
                  </svg>
                {% when 'inventory_2' %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="size-6"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
                  </svg>
                {% when 'spa' %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="size-6"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-2.25-1.313M21 7.5v2.25m0-2.25-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3 2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75 2.25-1.313M12 21.75V19.5m0 2.25-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25" />
                  </svg>
                {% when 'verified_user' %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="size-6"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
                  </svg>

                {% else %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="w-[28px] h-[28px]"
                  >
                    <circle cx="12" cy="12" r="10"/>
                  </svg>
              {% endcase %}
            </div>
            <div class="flex flex-col flex-grow">
              <h3 class="text-[22px] font-semibold text-[#1a201b] leading-tight mb-3">{{ block.settings.title }}</h3>
              <p class="text-[14px] text-gray-500 leading-relaxed mb-6">{{ block.settings.text }}</p>
            </div>
          </div>
          <a
            href="{{ block.settings.link_url | default: '#' }}"
            class="w-11 h-11 bg-gray-50 hover:bg-[#0f3f21] transition-colors rounded-full flex items-center justify-center mt-auto shrink-0 border border-gray-100 group-hover:shadow-md"
          >
            <span class="text-[20px] text-[#1a201b]">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </span>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Organic Why Us",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Badge Text",
      "default": "Why Choose Us!"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Choose Our Organic Farm?"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Left Image"
    },
    {
      "type": "text",
      "id": "floating_badge_title",
      "label": "Floating Badge Title",
      "default": "Join our active Farm community"
    },
    {
      "type": "text",
      "id": "floating_badge_stat",
      "label": "Floating Badge Stat",
      "default": "350+"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Material Icon Name",
          "default": "eco"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100% Organic Products"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "No chemicals. No compromises."
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL (Applies to Arrow button)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Organic Why Us",
      "blocks": [
        {
          "type": "feature",
          "settings": { "icon": "eco", "title": "100% Organic Products", "text": "No chemicals. No compromises." }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "inventory_2",
            "title": "Farm-to-Table Freshness",
            "text": "Our fields to your home, always fresh."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "spa",
            "title": "Sustainable Farming",
            "text": "Protecting nature through eco-friendly practices."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "verified_user",
            "title": "Local & Trusted",
            "text": "Supporting community health with trusted quality."
          }
        }
      ]
    }
  ]
}
{% endschema %}
