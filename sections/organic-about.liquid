<style>
  .custom-about-heading p {
    display: inline;
  }
  .custom-about-heading strong {
    font-weight: 800;
    color: #1a201b;
    position: relative;
  }
  /* Pseudo-element for the leaf above the first bold text */
  .custom-about-heading strong:first-of-type::before {
    content: '';
    position: absolute;
    top: -24px;
    left: 50%;
    transform: translateX(-50%);
    width: 28px;
    height: 28px;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg viewBox='0 0 24 24' fill='%236fac2a' xmlns='http://www.w3.org/2000/svg'%3e%3cpath d='M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22l1-2.3A13.89,13.89,0,0,0,20.53,12Z'/%3e%3cpath d='M17,8c-1.63-3.8-7.8-5.9-13-3.8l.94,1.88C10.15,4,13.8,6.17,17,8Z'/%3e%3c/svg%3e");
    background-size: contain;
    background-repeat: no-repeat;
    pointer-events: none;
  }
  .custom-about-heading em {
    font-style: normal;
    color: #45a420;
  }
</style>

<section
  class="py-12 lg:py-24 bg-[#f4f7f5] overflow-hidden relative full-width flex justify-center items-center"
  id="Section-{{ section.id }}"
>
  <div class="max-w-[1440px] mx-auto px-4 lg:px-6 grid grid-cols-1 lg:grid-cols-[1fr_2fr_1fr] gap-8 lg:gap-4 items-center relative z-10 w-full min-h-[500px]">
    <!-- Left Images (Grid on mobile, Absolute on LG) -->
    <div class="lg:absolute left-0 top-0 bottom-0 w-full lg:w-[240px] z-0 pointer-events-none flex lg:block flex-row justify-center gap-4 h-[200px] lg:h-auto overflow-hidden lg:overflow-visible">
      <!-- Top Left Image -->
      <div class="lg:absolute top-[5%] lg:left-[20px] w-1/2 max-w-[180px] lg:w-[180px] h-full lg:h-[240px] rounded-[24px] overflow-hidden shadow-sm border border-black/5 pointer-events-auto hover:scale-105 transition-transform duration-500">
        {% if section.settings.image_1 != blank %}
          {{ section.settings.image_1 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
        {% else %}
          <img
            src="{{ 'about-1.jpg' | file_img_url : 'original' }}"
            alt="Hero Image"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100"
            loading="eager"
            fetchpriority="auto"
            height="300"
            width="300"
            style="height: 100%;"
          >
        {% endif %}
      </div>
      <!-- Bottom Left Image -->
      <div class="lg:absolute bottom-[0%] lg:left-[60px] w-1/2 max-w-[200px] lg:w-[200px] h-full lg:h-[260px] rounded-[24px] overflow-hidden shadow-sm border border-black/5 pointer-events-auto hover:scale-105 transition-transform duration-500">
        {% if section.settings.image_3 != blank %}
          {{ section.settings.image_3 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
        {% else %}
          <img
            src="{{ 'about-2.png' | file_img_url : 'original' }}"
            alt="Hero Image"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100"
            loading="eager"
            fetchpriority="auto"
            height="300"
            width="300"
            style="height: 100%;"
          >
        {% endif %}
      </div>
    </div>

    <!-- Right Images (Absolute on LG) -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[240px] z-0 pointer-events-none">
      <!-- Top Right Image -->
      <div class="absolute top-[10%] right-0 xl:right-[0px] w-[220px] h-[280px] rounded-[24px] overflow-hidden shadow-sm border border-black/5 pointer-events-auto hover:scale-105 transition-transform duration-500">
        {% if section.settings.image_2 != blank %}
          {{ section.settings.image_2 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
        {% else %}
          <img
            src="{{ 'about-2.png' | file_img_url : 'original' }}"
            alt="Hero Image"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100"
            loading="eager"
            fetchpriority="auto"
            height="300"
            width="300"
            style="height: 100%;"
          >
        {% endif %}
      </div>
      <!-- Bottom Right Image -->
      <div class="absolute bottom-[-10%] right-[40px] xl:right-[100px] w-[180px] h-[220px] rounded-[24px] overflow-hidden shadow-sm border border-black/5 pointer-events-auto hover:scale-105 transition-transform duration-500">
        {% if section.settings.image_4 != blank %}
          {{ section.settings.image_4 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
        {% else %}
          <img
            src="{{ 'about-3.png' | file_img_url : 'original' }}"
            alt="Hero Image"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100"
            loading="eager"
            fetchpriority="auto"
            height="300"
            width="300"
            style="height: 100%;"
          >
        {% endif %}
      </div>
    </div>

    <!-- Center Content -->
    <div class="lg:col-start-2 lg:col-span-1 flex flex-col gap-6 items-center justify-center text-center z-10 w-full max-w-[700px] mx-auto pt-10 pb-10">
      {% if section.settings.subheading != blank %}
        <span class="inline-flex items-center gap-2 text-gray-600 border border-gray-200 px-3.5 py-1.5 rounded-full text-[12px] font-medium tracking-wide mb-6 bg-white shadow-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-[#0f3f21] mr-2"></span>

          {{ section.settings.subheading }}
        </span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <div class="custom-about-heading text-[26px] md:text-[34px] leading-[1.4] text-gray-800 mb-6 font-medium tracking-tight">
          {{ section.settings.heading }}
        </div>
      {% endif %}

      {% if section.settings.content != blank %}
        <div class="text-[13px] md:text-[14px] leading-relaxed text-gray-800/80 max-w-[600px] mb-8 font-medium">
          {{ section.settings.content }}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a
          {% if section.settings.button_link != blank %}
            href="{{ section.settings.button_link }}"
          {% else %}
            href="#"
          {% endif %}
          class="inline-flex items-center gap-3 bg-[#0f3f21] text-white pl-6 pr-0.5 py-0.5 rounded-full font-bold text-[14px] hover:bg-[#72d342] transition-all active:scale-95 shadow-md shadow-green-500/10 hover:-translate-y-0.5"
        >
          {{ section.settings.button_label }}
          <span class="bg-white rounded-full w-10 h-10 flex items-center justify-center shadow-sm">
            <span class=" text-[16px] font-bold text-[#0f3f21] " data-icon="call_made">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-4"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </span>
          </span>
        </a>
      {% endif %}
    </div>

    <!-- Mobile Images Grid -->
    <div class="grid grid-cols-2 gap-4 lg:hidden mt-8 w-full px-4">
      <div class="h-48 rounded-[24px] overflow-hidden shadow-sm">
        {% if section.settings.image_1 != blank %}
          {{ section.settings.image_1 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
        {% else %}
          <img
            src="{{ 'about-4.png' | file_img_url : 'original' }}"
            alt="Hero Image"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100"
            loading="eager"
            fetchpriority="auto"
            height="300"
            width="300"
            style="height: 100%;"
          >
        {% endif %}
      </div>
      <div class="h-56 rounded-[24px] overflow-hidden mt-8 shadow-sm">
        {% if section.settings.image_2 != blank %}
          {{ section.settings.image_2 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
        {% else %}
          <img
            src="{{ 'about-2.png' | file_img_url : 'original' }}"
            alt="Hero Image"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100"
            loading="eager"
            fetchpriority="auto"
            height="300"
            width="300"
            style="height: 100%;"
          >
        {% endif %}
      </div>
      <div class="h-64 rounded-[24px] overflow-hidden -mt-4 shadow-sm">
        {% if section.settings.image_3 != blank %}
          {{ section.settings.image_3 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
        {% else %}
          <img
            src="{{ 'about-1.jpg' | file_img_url : 'original' }}"
            alt="Hero Image"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100"
            loading="eager"
            fetchpriority="auto"
            height="300"
            width="300"
            style="height: 100%;"
          >
        {% endif %}
      </div>
      <div class="h-48 rounded-[24px] overflow-hidden mt-4 shadow-sm">
        {% if section.settings.image_4 != blank %}
          {{ section.settings.image_4 | image_url: width: 400 | image_tag: class: 'w-full h-full object-cover' }}
        {% else %}
          <img
            src="{{ 'about-3.png' | file_img_url : 'original' }}"
            alt="Hero Image"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000 bg-gray-100"
            loading="eager"
            fetchpriority="auto"
            height="300"
            width="300"
            style="height: 100%;"
          >
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Organic About",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Badge Text",
      "default": "About Us"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Use italic to make text green, use bold to make it thick black.",
      "default": "<p>At <strong>Organic</strong>, we are passionate about growing fresh, chemical-free produce. Nestled in the <em>heart of nature</em>, our <em>farm uses sustainable farming practices to protect the environment and deliver the healthiest food</em> to your table. Every seed we plant is a step toward a greener, healthier future.</p>"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content Paragraph",
      "default": "<p>We are dedicated to growing fresh, chemical-free produce through sustainable farming. Nestled in nature, our farm prioritizes protecting the environment while delivering healthy, high-quality food to your table.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Floating Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Top Left Image"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Bottom Left Image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Top Right Image"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Bottom Right Image"
    }
  ],
  "presets": [
    {
      "name": "Organic About"
    }
  ]
}
{% endschema %}
