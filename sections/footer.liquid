<footer
  class="relative min-h-[920px] flex flex-col justify-between overflow-hidden"
  style="width: 100vw; margin-left: calc(50% - 50vw);"
  id="Section-{{ section.id }}"
>
  {%- if section.settings.bg_image != blank -%}
    {{
      section.settings.bg_image
      | image_url: width: 2400
      | image_tag: class: 'absolute inset-0 w-full h-full object-cover z-0 pointer-events-none'
    }}
  {%- else -%}
    <img
      src="{{ 'footer.jpg' | file_url }}"
      width="1440"
      height="1080"
      alt="Footer Background"
      class="absolute inset-0 w-full h-full object-cover z-0 pointer-events-none"
    >
  {%- endif -%}

  <!-- Smooth Top Transition Overlay -->
  <div
    class="absolute top-0 left-0 w-full h-64 bg-gradient-to-b from-white via-white/80 to-transparent z-[1] pointer-events-none"
  ></div>

  <!-- Smooth Bottom Dark Transition Overlay -->
  <div
    class="absolute bottom-0 left-0 w-full h-64 bg-gradient-to-t from-[#1a201b] via-[#1a201b]/70 to-transparent z-[1] pointer-events-none"
  ></div>

  <div class="flex-1 flex flex-col items-center justify-center pt-32 pb-16 relative z-10 w-full px-4 text-center">
    <h2 class="text-4xl md:text-[54px] font-medium text-[#1a201b] mb-10 tracking-tight">
      {{ section.settings.heading }}
    </h2>

    <a
      href="{{ section.settings.button_link | default: '#' }}"
      class="inline-flex items-center bg-white rounded-full pl-6 pr-1 py-1 group shadow-sm hover:shadow-md transition-all"
    >
      <span class="text-[#1a201b] text-[14px] font-medium mr-4">{{ section.settings.button_text }}</span>
      <span class="bg-[#0f3f21] text-white w-9 h-9 rounded-full flex items-center justify-center group-hover:bg-[#005000] transition-colors">
        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
          <path d="M9.29 15.88L13.17 12 9.29 8.12a.996.996 0 1 1 1.41-1.41l4.59 4.59c.39.39.39 1.02 0 1.41L10.7 17.3a.996.996 0 0 1-1.41 0c-.38-.39-.39-1.03 0-1.42z"/>
        </svg>
      </span>
    </a>
  </div>

  <div class="w-full px-8 pb-8 relative z-10 flex flex-col md:flex-row justify-between items-center gap-4 text-white/80">
    <div class="flex items-center">
      {%- if section.settings.brand_logo != blank -%}
        <img
          src="{{ section.settings.brand_logo | image_url: width: 150 }}"
          height="24"
          width="24"
          alt="{{ shop.name }}"
          class="h-6 w-auto object-contain"
        >
      {%- else -%}
        <span class="text-xs font-bold tracking-widest uppercase">{{ shop.name }}</span>
      {%- endif -%}
    </div>

    <p class="text-[10px] tracking-[0.15em] uppercase font-medium text-center">
      &copy; {{ 'now' | date: '%Y' }}
      {{ shop.name }}. ALL RIGHTS RESERVED.
    </p>

    <div class="flex items-center gap-2">
      {%- if section.settings.show_payment_icons -%}
        {%- assign enabled_payment_types = shop.enabled_payment_types -%}
        {%- if enabled_payment_types == blank -%}
          {%- assign enabled_payment_types = 'visa,master,american_express,paypal' | split: ',' -%}
        {%- endif -%}

        {%- for type in enabled_payment_types -%}
          <span class="opacity-70 grayscale hover:grayscale-0 hover:opacity-100 transition-all">
            {{ type | payment_type_svg_tag: class: 'w-8 h-auto' }}
          </span>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Organic Footer CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The new era of market gardening."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Get in Touch"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "header",
      "content": "Brand & Footer Elements"
    },
    {
      "type": "image_picker",
      "id": "brand_logo",
      "label": "Store Brand Logo",
      "info": "Optional. Will replace the text store name at the bottom left."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Organic Footer CTA"
    }
  ]
}
{% endschema %}
