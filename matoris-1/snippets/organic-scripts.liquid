{% doc %}
  Injects core JavaScript libraries like GSAP for UI animations.
{% enddoc %}

<!-- GSAP Core -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
<!-- GSAP ScrollTrigger (very popular for landing page scrolling effects) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>

<script>
  // Wait until the DOM is fully loaded before triggering animations
  document.addEventListener('DOMContentLoaded', () => {
    gsap.registerPlugin(ScrollTrigger);

    // Write your GSAP animations here!
    // Example: Fade down the Hero section Header on page load
    gsap.from(".font-headline", {
      opacity: 0,
      y: -30,
      stagger: 0.2, // Adds a slight delay between each element found
      duration: 1,
      ease: "power3.out"
    });
  });
</script>
