<section class="py-32 bg-surface-container-low" id="Section-{{ section.id }}">
  <div class="max-w-[1200px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
    <div class="relative">
      <div class="rounded-[48px] overflow-hidden">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 800 | image_tag: class: 'w-full aspect-[4/5] object-cover' }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'w-full aspect-[4/5] object-cover bg-surface-variant' }}
        {% endif %}
      </div>
      
      <div class="absolute top-12 right-12 bg-white/20 backdrop-blur-md p-6 rounded-3xl border border-white/30 text-white">
        <p class="font-bold text-xl leading-tight">{{ section.settings.floating_badge_title }}</p>
        <p class="text-xs mt-2 opacity-80">{{ section.settings.floating_badge_text }}</p>
      </div>
    </div>
    
    <div>
      {% if section.settings.subheading != blank %}
        <span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-xs font-bold tracking-widest uppercase mb-4">{{ section.settings.subheading }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="text-4xl font-headline font-bold text-on-surface mb-12">{{ section.settings.heading }}</h2>
      {% endif %}
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {% for block in section.blocks %}
          <div class="p-8 bg-surface-container-lowest rounded-3xl group" {{ block.shopify_attributes }}>
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary mb-6">
              <span class="material-symbols-outlined" data-icon="{{ block.settings.icon }}">{{ block.settings.icon }}</span>
            </div>
            <h4 class="font-bold mb-3">{{ block.settings.title }}</h4>
            <p class="text-sm text-on-surface-variant mb-4">{{ block.settings.text }}</p>
            {% if block.settings.link_text != blank %}
              <a class="text-primary font-bold text-sm inline-flex items-center gap-2 group-hover:gap-3 transition-all" {% if block.settings.link_url != blank %}href="{{ block.settings.link_url }}"{% endif %}>
                  {{ block.settings.link_text }} <span class="material-symbols-outlined text-xs" data-icon="arrow_forward">arrow_forward</span>
              </a>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Organic Why Us",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "text",
      "id": "floating_badge_title",
      "label": "Floating Badge Title",
      "default": "Join our active farm community"
    },
    {
      "type": "text",
      "id": "floating_badge_text",
      "label": "Floating Badge Text",
      "default": "5,000+ Members and counting"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Why Choose Us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Choose Our Organic Farm?"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Google Material Icon Name",
          "default": "eco"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100% Organic Products"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "No synthetic pesticides or GMOs used in any of our crops."
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Organic Why Us",
      "blocks": [
        { "type": "feature", "settings": { "icon": "eco", "title": "100% Organic Products" } },
        { "type": "feature", "settings": { "icon": "shutter_speed", "title": "Farm-to-Table Freshness" } },
        { "type": "feature", "settings": { "icon": "psychology", "title": "Sustainable Farming" } },
        { "type": "feature", "settings": { "icon": "verified", "title": "Local & Trusted" } }
      ]
    }
  ]
}
{% endschema %}
