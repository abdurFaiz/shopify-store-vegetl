<section class="py-12 lg:py-24 bg-[#f4f7f5] full-width w-full" id="Section-{{ section.id }}">
  <div class="max-w-[1300px] mx-auto px-4 lg:px-6 text-center mb-10 lg:mb-16">
    {% if section.settings.subheading != blank %}
      <span class="inline-flex items-center text-gray-600 border border-gray-200 px-3.5 py-1.5 rounded-full text-[12px] font-medium tracking-wide mb-6 bg-white shadow-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-[#006400] mr-2"></span>
        {{ section.settings.subheading }}
      </span>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="text-3xl lg:text-[48px] leading-tight font-normal text-[#1a201b] tracking-tight">
        {{ section.settings.heading }}
      </h2>
    {% endif %}
  </div>

  <div class="max-w-[1300px] mx-auto px-4 xl:px-6 grid grid-cols-1 lg:grid-cols-2 gap-4">
    <!-- LEFT ALIGNED: Large Image with Cutout Badge -->
    <div class="relative w-full h-[400px] lg:h-auto min-h-[400px] lg:min-h-[600px] rounded-[32px] lg:rounded-[40px] overflow-hidden isolate border border-black/5">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag: class: 'w-full h-full object-cover absolute inset-0 z-0'
        }}
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-full object-cover absolute inset-0 z-0 bg-gray-200' }}
      {% endif %}

      <!-- Squircle Cutout Wrapper -->
      <div class="absolute bottom-0 left-0 bg-[#f4f7f5] pt-2.5 pr-2.5 rounded-tr-[44px] z-10 pointer-events-auto">
        <!-- SVG Inverted Corners -->
        <svg class="absolute -top-[28px] left-0 w-[28px] h-[28px] fill-[#f4f7f5]" viewBox="0 0 24 24">
          <path d="M 24,24 A 24,24 0 0 1 0,0 L 0,24 Z" />
        </svg>
        <svg class="absolute bottom-0 -right-[28px] w-[28px] h-[28px] fill-[#f4f7f5]" viewBox="0 0 24 24">
          <path d="M 24,24 A 24,24 0 0 1 0,0 L 0,24 Z" />
        </svg>

        <!-- White Floating Badge Content -->
        <div class="bg-white rounded-[32px] rounded-bl-[24px] p-6 shadow-sm min-w-[220px]">
          <div class="flex items-center -space-x-3 mb-4">
            <img
              src="https://i.pravatar.cc/100?img=5"
              alt="Avatar"
              width="100"
              height="100"
              class="w-[40px] h-[40px] rounded-full border-[3px] border-white object-cover bg-gray-100 z-30"
            >
            <img
              src="https://i.pravatar.cc/100?img=1"
              alt="Avatar"
              width="100"
              height="100"
              class="w-[40px] h-[40px] rounded-full border-[3px] border-white object-cover bg-gray-100 z-20"
            >
            <img
              src="https://i.pravatar.cc/100?img=3"
              alt="Avatar"
              width="100"
              height="100"
              class="w-[40px] h-[40px] rounded-full border-[3px] border-white object-cover bg-gray-100 z-10"
            >
            <div class="w-[40px] h-[40px] rounded-full border-[3px] border-white bg-[#83e950] text-[#1a201b] text-[11px] font-bold flex items-center justify-center z-0">
              {{ section.settings.floating_badge_stat }}
            </div>
          </div>
          <p class="font-bold text-[16px] text-[#1a201b] leading-tight max-w-[150px]">
            {{ section.settings.floating_badge_title }}
          </p>
        </div>
      </div>
    </div>

    <!-- RIGHT ALIGNED: Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 h-full">
      {% for block in section.blocks %}
        <div
          class="bg-white rounded-[40px] p-6 flex flex-col group transition-all hover:shadow-xl hover:shadow-black/5 hover:-translate-y-1"
          {{ block.shopify_attributes }}
        >
          <div class="w-[56px] h-[56px] bg-[#f4f7f5] text-green-800 rounded-[24px] rounded-bl-[8px] flex items-center justify-center mb-10 shrink-0 border border-green-900/5">
            <span class="material-symbols-outlined text-[28px]" data-icon="{{ block.settings.icon }}">
              {{- block.settings.icon -}}
            </span>
          </div>

          <div class="flex flex-col flex-grow">
            <h3 class="text-[22px] font-semibold text-[#1a201b] leading-tight mb-3">{{ block.settings.title }}</h3>
            <p class="text-[14px] text-gray-500 leading-relaxed mb-6">{{ block.settings.text }}</p>
          </div>

          <a
            href="{{ block.settings.link_url | default: '#' }}"
            class="w-11 h-11 bg-gray-50 hover:bg-[#83e950] transition-colors rounded-full flex items-center justify-center mt-auto shrink-0 border border-gray-100 group-hover:shadow-md"
          >
            <span class="material-symbols-outlined text-[20px] text-[#1a201b]">north_east</span>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Organic Why Us",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Badge Text",
      "default": "Why Choose Us!"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Choose Our Organic Farm?"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Left Image"
    },
    {
      "type": "text",
      "id": "floating_badge_title",
      "label": "Floating Badge Title",
      "default": "Join our active Farm community"
    },
    {
      "type": "text",
      "id": "floating_badge_stat",
      "label": "Floating Badge Stat",
      "default": "350+"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Material Icon Name",
          "default": "eco"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100% Organic Products"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "No chemicals. No compromises."
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL (Applies to Arrow button)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Organic Why Us",
      "blocks": [
        {
          "type": "feature",
          "settings": { "icon": "eco", "title": "100% Organic Products", "text": "No chemicals. No compromises." }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "inventory_2",
            "title": "Farm-to-Table Freshness",
            "text": "Our fields to your home, always fresh."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "spa",
            "title": "Sustainable Farming",
            "text": "Protecting nature through eco-friendly practices."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "verified_user",
            "title": "Local & Trusted",
            "text": "Supporting community health with trusted quality."
          }
        }
      ]
    }
  ]
}
{% endschema %}
