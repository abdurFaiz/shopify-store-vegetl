<footer class="relative min-w-full full-width flex flex-col justify-between min-h-[600px] pt-[25vh] pb-8 isolate overflow-hidden" id="Section-{{ section.id }}">
  <!-- BACKGROUND IMAGE -->
  {% if section.settings.bg_image != blank %}
    {{ section.settings.bg_image | image_url: width: 2000 | image_tag: class: 'absolute inset-0 w-full h-full object-cover z-[-3]' }}
  {% else %}
    <div class="absolute inset-0 w-full h-full bg-gradient-to-b from-[#f9f8f2] to-[#3a5223] z-[-3]"></div>
  {% endif %}
  
  <!-- Seamless Top Transition Overlay (Fades out the hard line from the white section above) -->
  <div class="absolute top-0 left-0 w-full h-48 md:h-64 bg-gradient-to-b from-white via-white/80 to-transparent z-[-2] pointer-events-none"></div>

  <!-- Subtle gradient to ensure bottom white text is always perfectly readable over the crops -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent z-[-1] pointer-events-none"></div>

  <!-- CENTER CTA BLOCK -->
  <div class="flex flex-col items-center text-center z-10 max-w-4xl mx-auto w-full">
    <h2 class="text-[#1a201b] font-medium text-[44px] md:text-[56px] leading-[1.1] tracking-tight mb-8">
      {{ section.settings.cta_heading }}
    </h2>
    
    {% if section.settings.cta_button_text != blank %}
      <a href="{{ section.settings.cta_link | default: '#' }}" class="inline-flex items-stretch bg-white shadow-xl rounded-full overflow-hidden group hover:-translate-y-1 transition-all duration-300">
        <span class="px-6 py-2.5 text-[#1a201b] text-[14px] font-medium">{{ section.settings.cta_button_text }}</span>
        <span class="bg-[#006400] px-4 flex items-center justify-center group-hover:bg-[#bde817] transition-colors">
          <span class="material-symbols-outlined text-[18px] text-white font-bold">keyboard_arrow_right</span>
        </span>
      </a>
    {% endif %}
  </div>

  <!-- BOTTOM FOOTER (Logo, Nav, Contact, Jargon) -->
  <div class="z-10 mt-auto pt-32 w-full max-w-full mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10 md:gap-8 mb-12 lg:mb-16 text-white">
      
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'brand' %}
            <div class="lg:col-span-4 flex flex-col gap-4 pr-10" {{ block.shopify_attributes }}>
              {% if block.settings.logo != blank %}
                 <img src="{{ block.settings.logo | image_url: width: 300 }}" width="1440" height="1080" alt="{{ shop.name }}" class="w-auto h-8 object-contain">
              {% else %}
                 <h3 class="text-white text-2xl font-bold uppercase tracking-widest">{{ shop.name }}</h3>
              {% endif %}
              
              {% if block.settings.jargon != blank %}
                <p class="text-[14px] text-white/70 leading-relaxed font-medium max-w-[300px] mt-2">
                  {{ block.settings.jargon }}
                </p>
              {% endif %}
            </div>
            
          {% when 'link_list' %}
            <div class="lg:col-span-2 flex flex-col gap-5" {{ block.shopify_attributes }}>
              <h4 class="text-white font-bold text-[14px] uppercase tracking-wider">{{ block.settings.heading }}</h4>
              <ul class="flex flex-col gap-3">
                {% for link in block.settings.menu.links %}
                  <li><a href="{{ link.url }}" class="text-[14px] text-white/70 hover:text-[#d2f534] font-medium transition-colors">{{ link.title }}</a></li>
                {% endfor %}
              </ul>
            </div>
            
          {% when 'contact' %}
            <div class="lg:col-span-4 flex flex-col gap-5" {{ block.shopify_attributes }}>
              <h4 class="text-white font-bold text-[14px] uppercase tracking-wider">{{ block.settings.heading }}</h4>
              <div class="text-[14px] text-white/70 space-y-3 font-medium">
                {{ block.settings.contact_info }}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
      
    </div>

    <!-- COPYRIGHT ROW -->
    <div class=" px-6 pt-6 flex flex-col md:flex-row justify-between items-center gap-4 text-[12px] font-medium text-white/60 tracking-wider">
      <div class="uppercase">© {{ 'now' | date: "%Y" }} {{ shop.name }}. All Rights Reserved.</div> 
      <div class="flex gap-6 uppercase">
        {% if section.settings.show_payment_icons %}
           {% for type in shop.enabled_payment_types %}
             <span class="opacity-60 grayscale hover:grayscale-0 hover:opacity-100 transition-all">{{ type | payment_type_svg_tag: class: 'w-8 h-auto' }}</span>
           {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
  
</footer>

{% schema %}
{
  "name": "Organic Footer",
  "max_blocks": 5,
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image",
      "info": "We recommend a large scenic image with a light sky and dark bottom landscape."
    },
    {
      "type": "header",
      "content": "Center Call-To-Action"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA Heading",
      "default": "Join us in our growth"
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "Button Text",
      "default": "Inquire"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Logo & Jargon",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        },
        {
          "type": "textarea",
          "id": "jargon",
          "label": "Brand Jargon/Description",
          "default": "Cultivating the future of sustainable farming, providing organic produce from field to market safely."
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu Links",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Menu Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Navigation Menu"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact Information",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Get in touch"
        },
        {
          "type": "richtext",
          "id": "contact_info",
          "label": "Contact Info",
          "default": "<p>123 Farming Valley Road<br>Organic District, OR 90210</p><p>Call us: +1 (555) 123-4567<br>Email: hello@organicfarm.com</p>"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "brand"
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Explore"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Legal"
        }
      },
      {
        "type": "contact"
      }
    ]
  }
}
{% endschema %}
