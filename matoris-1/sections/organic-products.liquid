<section class="py-32 bg-white" id="Section-{{ section.id }}">
  <div class="max-w-[1200px] mx-auto px-6 text-center mb-16">
    {% if section.settings.subheading != blank %}
      <span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-xs font-bold tracking-widest uppercase mb-4">
        {{ section.settings.subheading }}
      </span>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="text-4xl font-headline font-bold text-on-surface">
        {{ section.settings.heading }}
      </h2>
    {% endif %}
  </div>

  <div class="max-w-[1200px] mx-auto px-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
      <div class="group bg-surface-container-lowest rounded-2xl p-4 transition-all hover:shadow-2xl hover:shadow-primary/5 border border-outline-variant/5">
        <a href="{{ product.url }}" class="block aspect-square rounded-xl overflow-hidden mb-6 bg-surface">
          {% if product.featured_image != blank %}
             {{ product.featured_image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover group-hover:scale-110 transition-transform duration-500' }}
          {% else %}
             {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover group-hover:scale-110 transition-transform duration-500 bg-surface' }}
          {% endif %}
        </a>
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-headline font-bold text-lg mb-1"><a href="{{ product.url }}">{{ product.title }}</a></h3>
            <p class="text-sm text-on-surface-variant mb-4">{{ product.type | default: 'Organic Product' }}</p>
            <p class="text-primary font-bold text-xl">{{ product.price | money }}</p>
          </div>
          <form method="post" action="/cart/add" class="inline">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
            <button type="submit" class="w-12 h-12 rounded-full bg-on-surface flex items-center justify-center text-white hover:bg-primary transition-colors">
              <span class="material-symbols-outlined text-xl" data-icon="shopping_cart">shopping_cart</span>
            </button>
          </form>
        </div>
      </div>
    {%- else -%}
      {%- for i in (1..section.settings.products_to_show) -%}
        <div class="group bg-surface-container-lowest rounded-2xl p-4 transition-all hover:shadow-2xl hover:shadow-primary/5 border border-outline-variant/5">
          <div class="block aspect-square rounded-xl overflow-hidden mb-6 bg-surface">
             {{ 'product-' | append: i | placeholder_svg_tag: 'w-full h-full object-cover group-hover:scale-110 transition-transform duration-500 bg-surface' }}
          </div>
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-headline font-bold text-lg mb-1">Example Product Title</h3>
              <p class="text-sm text-on-surface-variant mb-4">Grown with natural fertilizers</p>
              <p class="text-primary font-bold text-xl">$5.99</p>
            </div>
            <button class="w-12 h-12 rounded-full bg-on-surface flex items-center justify-center text-white hover:bg-primary transition-colors">
              <span class="material-symbols-outlined text-xl" data-icon="shopping_cart">shopping_cart</span>
            </button>
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Organic Products Grid",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Freshest Picks"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Organic Products Grid"
    }
  ]
}
{% endschema %}
