<header
  class="fixed top-0 left-0 w-full z-50 bg-white/80 backdrop-blur-xl shadow-sm transition-transform duration-300 ease-in-out"
  id="organic-header-{{ section.id }}"
>
  <div class="flex justify-between items-center max-w-full mx-auto px-6 h-20">
    <!-- Brand Logo -->
    <a
      href="{{ routes.root_url }}"
      class="text-2xl font-bold text-[#006400] flex items-center gap-2 font-headline"
    >
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 200 | image_tag: class: 'h-8 w-auto' }}
      {%- else -%}
        <span class="material-symbols-outlined text-primary-container" data-icon="eco">eco</span>
        {{ shop.name }}
      {%- endif -%}
    </a>

    <!-- Navigation Links -->
    <nav class="hidden md:flex items-center gap-6 font-plus-jakarta-sans text-md font-medium">
      {%- for link in section.settings.menu.links -%}
        <a
          class="text-slate-700 hover:text-[#006400] px-3 py-2 rounded-full bg-gray-100 transition-colors {% if link.active %} text-[#006400] font-medium{% endif %}"
          href="{{ link.url }}"
        >
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>

    <!-- Trailing Actions -->
    <div class="flex items-center gap-6">
      <a
        href="{{ routes.cart_url }}"
        class="material-symbols-outlined rounded-full border border-gray-200 text-slate-600 hover:bg-emerald-50/50 p-2.5 rounded-full transition-all relative"
        data-icon="shopping_basket"
      >
        shopping_basket
        {% if cart.item_count > 0 %}
          <span class="absolute top-0 right-0 bg-primary text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center">
            {{- cart.item_count -}}
          </span>
        {% endif %}
      </a>
      {% if section.settings.button_label != blank %}
        <div class="flex items-center justify-center">

          <a
            {% if section.settings.button_link != blank %}
              href="{{ section.settings.button_link }}"
            {% endif %}
            class="bg-[#006400] text-white pl-4 pr-1 py-1 rounded-full font-medium text-md scale-95 active:scale-90 transition-transform shadow-lg shadow-primary/20 flex items-center gap-2"
          >
            {{ section.settings.button_label }}
            <span class="material-symbols-outlined text-sm text-[#006400] bg-white rounded-full px-2.5 py-1.5" data-icon="call_made">call_made</span>
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    let lastScrollY = window.scrollY;
    const header = document.getElementById('organic-header-{{ section.id }}');
    
    if(!header) return;

    window.addEventListener('scroll', () => {
      const currentScrollY = window.scrollY;
      
      // If scrolling down, and we've scrolled past the header height (e.g. 50px)
      if (currentScrollY > lastScrollY && currentScrollY > 50) {
        header.style.transform = 'translateY(-100%)';
      } 
      // If scrolling up, or we are within the top 50px of the page
      else {
        header.style.transform = 'translateY(0)';
      }
      
      lastScrollY = currentScrollY;
    }, { passive: true });
  });
</script>
{% schema %}
{
  "name": "Organic Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Organic Header"
    }
  ]
}
{% endschema %}
