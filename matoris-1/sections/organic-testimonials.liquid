<section class="py-12 lg:py-24 bg-white full-width w-full overflow-hidden" id="Section-{{ section.id }}">
  <div class="max-w-[1300px] mx-auto px-4 lg:px-6 w-full">
    
    <!-- TOP HEADER -->
    <div class="mb-14 lg:mb-20">
      {% if section.settings.subheading != blank %}
        <span class="inline-flex items-center text-gray-600 border border-gray-200 px-3.5 py-1.5 rounded-full text-[12px] font-medium tracking-wide mb-6 bg-white shadow-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-[#006400] mr-2"></span>
          {{ section.settings.subheading }}
        </span>
      {% endif %}
      
      <div class="flex flex-col lg:flex-row lg:justify-between lg:items-end gap-6">
        {% if section.settings.heading != blank %}
          <!-- We use inline HTML in the default heading to get the bold/italic split -->
          <h2 class="text-4xl md:text-[52px] leading-tight text-[#1a201b] font-semibold tracking-tight max-w-[700px]">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
        
        {% if section.settings.description != blank %}
          <p class="max-w-[360px] text-[15px] text-gray-600 leading-relaxed text-left lg:text-right pb-2">
            {{ section.settings.description }}
          </p>
        {% endif %}
      </div>
    </div>
    
    <!-- MAIN CONTENT GRID -->
    <div class="grid grid-cols-1 lg:grid-cols-[0.6fr_1.3fr] gap-10 lg:gap-16 items-center">
      
      <!-- IMAGE -->
      <div class="w-full aspect-square md:aspect-[4/3] h-full  rounded-[40px] overflow-hidden">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1000 | image_tag: class: 'w-full h-full object-cover' }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-gray-100' }}
        {% endif %}
      </div>
      
      <!-- QUOTE & AUTHOR -->
      <div class="flex flex-col">
        
        <div class="text-[26px] sm:text-[30px] md:text-[36px] leading-[1.3] font-medium tracking-tight mb-12 sm:mb-16">
          <span class="text-[#1a201b]">“{{ section.settings.quote_highlight }}</span>
          <span class="text-gray-500">{{ section.settings.quote_text }}”</span>
        </div>
        
        <div class="flex items-center justify-between">
          <div class="flex flex-col">
            <span class="text-[#1a201b] font-bold text-[18px]">{{ section.settings.author_name }}</span>
            <span class="text-gray-500 text-[14px] mt-0.5">{{ section.settings.author_location }}</span>
          </div>
          
          <!-- ARROW NAVIGATION -->
          <div class="flex items-center gap-3">
            <button class="w-12 h-12 rounded-full border border-gray-200 flex items-center justify-center text-gray-600 hover:bg-gray-50 transition-colors shadow-sm">
              <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            </button>
            <button class="w-12 h-12 rounded-full bg-[#006400] flex items-center justify-center text-white hover:bg-green-800 transition-colors shadow-md">
              <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
            </button>
          </div>
        </div>
        
      </div>
      
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Organic Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Badge Text",
      "default": "Testimonials"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading (HTML Supported)",
      "default": "Real Stories From <span class='font-normal italic text-gray-700'>Our Farmers</span>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Right Description Text",
      "default": "Read real experiences from farmers who grow with us, sharing trust, quality, and success from field to market."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "header",
      "content": "Quote Selection"
    },
    {
      "type": "textarea",
      "id": "quote_highlight",
      "label": "Quote Highlight (Dark Text)",
      "default": "I have been farming for over 15 years, but working with this platform completely changed how "
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote Body (Gray Text)",
      "default": "I sell my produce. Fair prices, timely support, and genuine care for farmers made a real difference for my family and my land."
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author Name",
      "default": "Aaron Mitchell"
    },
    {
      "type": "text",
      "id": "author_location",
      "label": "Author Location",
      "default": "Florida, United States"
    }
  ],
  "presets": [
    {
      "name": "Organic Testimonials"
    }
  ]
}
{% endschema %}
