<section class="py-32 bg-white" id="Section-{{ section.id }}">
  <div class="max-w-[1200px] mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-20 items-center">
    <div>
      {% if section.settings.subheading != blank %}
        <span class="inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-xs font-bold tracking-widest uppercase mb-6">{{ section.settings.subheading }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="text-4xl font-headline font-bold text-on-surface mb-8">{{ section.settings.heading }}</h2>
      {% endif %}
      
      <div class="relative pl-12 border-l-4 border-primary/20">
        <span class="absolute left-0 top-0 text-6xl text-primary/20 font-serif leading-none">“</span>
        {% if section.settings.quote != blank %}
          <div class="text-2xl font-medium leading-relaxed italic mb-8">
              {{ section.settings.quote }}
          </div>
        {% endif %}
        
        <div class="flex items-center gap-4">
          {% if section.settings.avatar != blank %}
            {{ section.settings.avatar | image_url: width: 100 | image_tag: class: 'w-12 h-12 rounded-full object-cover' }}
          {% else %}
            <div class="w-12 h-12 rounded-full bg-slate-200"></div>
          {% endif %}
          <div>
            <h5 class="font-bold">{{ section.settings.author_name }}</h5>
            <div class="flex text-amber-400">
              <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
              <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
              <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
              <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
              <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="rounded-[40px] overflow-hidden shadow-2xl relative">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 800 | image_tag: class: 'w-full h-96 object-cover' }}
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'w-full h-96 object-cover bg-surface-variant' }}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Organic Testimonial",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Testimonial"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Say Our Customers"
    },
    {
      "type": "richtext",
      "id": "quote",
      "label": "Quote",
      "default": "<p>\"The quality of the vegetables from Organic Farm is incomparable. You can truly taste the freshness in every bite. Their commitment to sustainability is why I'll keep coming back.\"</p>"
    },
    {
      "type": "image_picker",
      "id": "avatar",
      "label": "Author Avatar"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author Name",
      "default": "Sarah M."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    }
  ],
  "presets": [
    {
      "name": "Organic Testimonial"
    }
  ]
}
{% endschema %}
